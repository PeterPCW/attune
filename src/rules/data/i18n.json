{
  "rules": [
    {
      "id": "I18N_HARDCODED_STRING",
      "name": "Hardcoded string instead of i18n",
      "category": "i18n",
      "severity": "medium",
      "frameworks": ["react", "vue", "svelte", "angular"],
      "catches": [
        "Hardcoded UI strings",
        "Can't translate app",
        "Single language only"
      ],
      "fix": [
        "Use t() or translate function",
        "Create translation files",
        "Support multiple languages"
      ],
      "recommendation": {
        "title": "Use i18n for strings",
        "description": "Hardcoded strings prevent localization. Use translation functions.",
        "library": "i18next, vue-i18n, ngx-translate"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "<[A-Z][a-zA-Z]+>[a-zA-Z]+</[A-Z]",
          "message": "Hardcoded text in JSX - use i18n",
          "fileExtensions": [".tsx", ".jsx"]
        }
      ]
    },
    {
      "id": "I18N_NO_LOCALE",
      "name": "Missing locale configuration",
      "category": "i18n",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Undefined supported languages",
        "Can't filter languages",
        "Inconsistent behavior"
      ],
      "fix": [
        "Define supportedLocales",
        "Configure fallback locale",
        "Validate locale codes"
      ],
      "recommendation": {
        "title": "Configure supported locales",
        "description": "Define supported locales for the application.",
        "library": "i18next"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "supportedLngs|supportedLocales|locales",
          "message": "Locale config found",
          "fileExtensions": [".ts", ".js", ".json"]
        }
      ]
    },
    {
      "id": "I18N_NO_FALLBACK",
      "name": "Missing fallback language",
      "category": "i18n",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Missing translations break UI",
        "No default language",
        "Blank strings shown"
      ],
      "fix": [
        "Set fallbackLng config",
        "Use common language as fallback",
        "Handle missing keys"
      ],
      "recommendation": {
        "title": "Set fallback language",
        "description": "Configure fallback when translation is missing.",
        "library": "i18next"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "fallbackLng|fallbackLocale|fallback",
          "message": "Fallback locale found",
          "fileExtensions": [".ts", ".js", ".json"]
        }
      ]
    },
    {
      "id": "I18N_PLURAL_NOTES",
      "name": "Plural forms not handled",
      "category": "i18n",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Incorrect plural forms shown",
        "Grammar errors in translations",
        "Wrong count displayed"
      ],
      "fix": [
        "Add plural forms to keys",
        "Use count variable",
        "Define all plural forms"
      ],
      "recommendation": {
        "title": "Handle plural forms",
        "description": "Different languages have different plural rules.",
        "library": "i18next plural"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "count\\s*[><=]|plural|one\\s*other",
          "message": "Plural handling found",
          "fileExtensions": [".json", ".ts"]
        }
      ]
    },
    {
      "id": "I18N_NO_DATE_FORMAT",
      "name": "Using hardcoded date formats",
      "category": "i18n",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Wrong date format per locale",
        "Confusing for users",
        "Hard to read dates"
      ],
      "fix": [
        "Use Intl.DateTimeFormat",
        "Pass locale to formatter",
        "Use date-fns or dayjs"
      ],
      "recommendation": {
        "title": "Use locale-aware date formatting",
        "description": "Date formats vary by locale. Use Intl.DateTimeFormat.",
        "library": "Intl, date-fns, dayjs"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "toLocaleDateString|format\\(\\d{2}|YYYY-MM-DD",
          "message": "Date formatting found - use locale-aware",
          "fileExtensions": [".ts", ".js", ".tsx", ".jsx"]
        }
      ]
    },
    {
      "id": "I18N_NO_NUMBER_FORMAT",
      "name": "Using hardcoded number formats",
      "category": "i18n",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Wrong number format per locale",
        "Wrong decimal separators",
        "Confusing for users"
      ],
      "fix": [
        "Use Intl.NumberFormat",
        "Pass locale to formatter",
        "Format numbers properly"
      ],
      "recommendation": {
        "title": "Use locale-aware number formatting",
        "description": "Number formats (decimal separators) vary by locale.",
        "library": "Intl.NumberFormat"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "toLocaleString|Intl\\.NumberFormat",
          "message": "Number formatting found",
          "fileExtensions": [".ts", ".js", ".tsx", ".jsx"]
        }
      ]
    }
  ]
}
