      "helpers": [
        {
          "name": "findMissingLandmarks",
          "params": {
            "message": "Missing semantic HTML landmarks",
            "landmarks": ["header", "nav", "main", "footer"]
          }
        }
      ]
    },
    {
      "id": "A11Y_AUTOPLAY_MEDIA",
      "name": "Auto-playing media without controls",
