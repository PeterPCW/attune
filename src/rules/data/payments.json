{
  "rules": [
    {
      "id": "PAY_NO_WEBHOOK_VERIFY",
      "name": "Webhook not verified",
      "category": "payments",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Fake webhook events",
        "Spoofed payment events",
        "Financial fraud"
      ],
      "fix": [
        "Verify webhook signature",
        "Use provider's verification lib",
        "Validate event payload"
      ],
      "recommendation": {
        "title": "Verify webhook signatures",
        "description": "Always verify webhook signatures to prevent spoofed payment events.",
        "library": "Stripe, PayPal webhooks"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "webhook|stripe|signature|constructEvent",
          "message": "Webhook found - verify signature",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "PAY_NO_IDEMPOTENCY",
      "name": "Payment request without idempotency",
      "category": "payments",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Duplicate charges",
        "Customer charged twice",
        "Financial loss"
      ],
      "fix": [
        "Add idempotency key to requests",
        "Use unique key per transaction",
        "Handle retry safely"
      ],
      "recommendation": {
        "title": "Use idempotency keys",
        "description": "Prevent duplicate charges by using idempotency keys for payment requests.",
        "library": "Stripe idempotency"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "idempotency|Idempotency-Key",
          "message": "Idempotency found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "PAY_NO_3DS",
      "name": "3D Secure not implemented",
      "category": "payments",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Not SCA compliant",
        "Payments rejected",
        "Legal issues"
      ],
      "fix": [
        "Enable 3D Secure",
        "Handle authentication flow",
        "Configure payment intents"
      ],
      "recommendation": {
        "title": "Implement 3D Secure",
        "description": "3D Secure is required for SCA compliance in EU.",
        "library": "Stripe 3D Secure"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "3ds|3-D Secure|threeDSecure|authentication",
          "message": "3D Secure found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "PAY_STORED_CARD",
      "name": "Storing card details directly",
      "category": "payments",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Storing card data",
        "PCI DSS violation",
        "Security breach risk"
      ],
      "fix": [
        "Use Stripe Elements or similar",
        "Store only token, not card data",
        "Never touch raw card data"
      ],
      "recommendation": {
        "title": "Use payment provider tokenization",
        "description": "Never store card details. Use provider tokenization (Stripe tokens, etc.)",
        "library": "Stripe Elements, payment tokens"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "card.*number|cvv|cardNumber|pan|creditCard",
          "message": "Card data found - use tokenization",
          "fileExtensions": [".ts", ".js", ".tsx", ".jsx"]
        }
      ]
    },
    {
      "id": "PAY_NO_REFUND",
      "name": "Missing refund functionality",
      "category": "payments",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No refund process",
        "Customer complaints",
        "Disputes and chargebacks"
      ],
      "fix": [
        "Implement refund API endpoint",
        "Handle partial refunds",
        "Track refund status"
      ],
      "recommendation": {
        "title": "Implement refund process",
        "description": "Have a clear refund process for returns and disputes.",
        "library": "Stripe refunds"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "refund|Refund",
          "message": "Refund found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "PAY_NO_WEBHOOK_RETRY",
      "name": "Webhook handler missing retry logic",
      "category": "payments",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Webhook handlers without retry/idempotency handling",
        "Missed payment events",
        "Duplicate processing"
      ],
      "fix": [
        "Check event ID for duplicates",
        "Store processed events",
        "Handle idempotently"
      ],
      "recommendation": {
        "title": "Handle webhook retries",
        "description": "Payment providers retry failed webhooks. Files with webhook/stripe/payment patterns should handle duplicates. Note: Files without payment-related patterns are ignored.",
        "library": "Webhook idempotency"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "webhook|stripe|payment|webhookHandler|paymentEvent",
          "message": "Payment/webhook handler found - verify idempotency handling",
          "fileExtensions": [".ts", ".js"],
          "excludePatterns": ["idempotent|processedIds|retryCount|handleRetry"]
        }
      ]
    },
    {
      "id": "PAY_SANDBOX_PROD",
      "name": "Sandbox API keys in production",
      "category": "payments",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Sandbox keys in production",
        "Payments don't process",
        "Real money lost"
      ],
      "fix": [
        "Use live keys in production",
        "Check environment config",
        "Verify keys match env"
      ],
      "recommendation": {
        "title": "Use production keys only in prod",
        "description": "Sandbox keys won't process real payments.",
        "library": "Environment config"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "sk_test|sandbox|stripe\\.com",
          "message": "Sandbox key detected",
          "fileExtensions": [".ts", ".js", ".env"]
        }
      ]
    }
  ]
}
