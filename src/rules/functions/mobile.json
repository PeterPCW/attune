{
  "version": "1.0",
  "functions": [
    {
      "id": "MOBILE_OFFLINE_FIRST",
      "name": "No offline support for critical features",
      "description": "Critical features should work offline using service workers.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "pwa"
      ],
      "category": "reliability",
      "recommendation": {
        "title": "Add offline support",
        "description": "Critical features should work offline using service workers.",
        "library": "Service Workers, Workbox"
      },
      "catches": [
        "App unusable without internet",
        "Poor user experience offline",
        "Failed requests when offline"
      ],
      "fix": [
        "Add service worker for caching",
        "Use Workbox for offline support",
        "Implement offline-first architecture"
      ],
      "condition": {
        "type": "regex",
        "pattern": "service-worker|workbox|offline|cache"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Offline support found"
      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
      "id": "MOBILE_NO_SPLASH",
      "name": "Missing splash screen",
      "description": "Splash screens improve perceived startup time on mobile.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "pwa"
      ],
      "category": "usability",
      "recommendation": {
        "title": "Add splash screen",
        "description": "Splash screens improve perceived startup time on mobile.",
        "library": "PWA"
      },
      "catches": [
        "White flash on app load",
        "Poor perceived performance",
        "Inconsistent user experience"
      ],
      "fix": [
        "Add splash screen to manifest",
        "Configure theme color",
        "Set loading screen background"
      ],
      "condition": {
        "type": "regex",
        "pattern": "splash|launch|loading.?screen"
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Splash screen found"
      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
      "id": "MOBILE_VIEWPORT",
      "name": "Missing viewport meta tag",
      "description": "Viewport meta tag is required for proper mobile rendering.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "usability",
      "recommendation": {
        "title": "Add viewport meta tag",
        "description": "Viewport meta tag is required for proper mobile rendering.",
        "library": "HTML"
      },
      "catches": [
        "Page not scaled for mobile",
        "Tiny text on small screens",
        "Poor mobile experience"
      ],
      "fix": [
        "Add viewport meta tag to HTML head",
        "Set width=device-width, initial-scale=1",
        "Test on actual mobile devices"
      ],
      "condition": {
        "type": "regex",
        "pattern": "viewport|meta.*width=device"
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Viewport meta found"
      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
      "id": "MOBILE_TAP_SIZE",
      "name": "Touch targets too small",
      "description": "Touch targets should be at least 44x44 pixels for accessibility.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "accessibility",
      "recommendation": {
        "title": "Increase touch target size",
        "description": "Touch targets should be at least 44x44 pixels for accessibility.",
        "library": "CSS"
      },
      "catches": [
        "Hard to tap small buttons",
        "Accessibility violations",
        "User frustration"
      ],
      "fix": [
        "Increase button size to 44x44px minimum",
        "Add adequate padding",
        "Test touch targets on actual devices"
      ],
      "condition": {
        "type": "regex",
        "pattern": "min-height|min-width|padding|44px|48px"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Touch target sizing found"
      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
      "id": "MOBILE_SWIPE_CONFLICT",
      "name": "Swipe gestures may conflict with browser",
      "description": "Custom swipe gestures may conflict with browser navigation. Add prevention.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "usability",
      "recommendation": {
        "title": "Handle swipe conflicts",
        "description": "Custom swipe gestures may conflict with browser navigation. Add prevention.",
        "library": "JavaScript"
      },
      "catches": [
        "Browser navigation conflicts with app gestures",
        "Unexpected back navigation",
        "Poor gesture experience"
      ],
      "fix": [
        "Call preventDefault on touchmove carefully",
        "Use passive: false for event listeners",
        "Test gestures on real devices"
      ],
      "condition": {
        "type": "regex",
        "pattern": "touchstart|touchmove|preventDefault|passive"
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Touch handling found"
      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
