{
  "rules": [
    {
      "id": "TRPC_PROCEDURE_SIDE_EFFECT",
      "name": "Mutation in query procedure",
      "category": "architecture",
      "severity": "high",
      "frameworks": ["nextjs", "react"],
      "catches": [
        "Database writes in query",
        "Side effects in read operations",
        "Caching issues"
      ],
      "fix": [
        "Use procedure.mutation for writes",
        "Keep queries pure",
        "Separate read and write logic"
      ],
      "recommendation": {
        "title": "Use mutation for side effects",
        "description": "Query procedures should be pure. Use mutation for side effects (database writes, etc.).",
        "library": "tRPC"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "procedure\\.query",
          "message": "tRPC query procedure detected"
        }
      ]
    },
    {
      "id": "TRPC_NO_INPUT_SCHEMA",
      "name": "Procedure without input schema",
      "category": "security",
      "severity": "medium",
      "frameworks": ["nextjs", "react"],
      "catches": [
        "No input validation",
        "Invalid data processed",
        "Security vulnerabilities"
      ],
      "fix": [
        "Add Zod schema to input",
        "Validate all procedure inputs",
        "Use .input(zodSchema)"
      ],
      "recommendation": {
        "title": "Add input validation schema",
        "description": "Procedures should have Zod input schemas for validation.",
        "library": "Zod"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "procedure\\.",
          "message": "tRPC procedure detected"
        }
      ]
    },
    {
      "id": "TRPC_NO_ERROR_HANDLING",
      "name": "No error handling in caller",
      "category": "reliability",
      "severity": "medium",
      "frameworks": ["nextjs", "react"],
      "catches": [
        "Uncaught errors crash app",
        "Poor error messages to users",
        "No error recovery"
      ],
      "fix": [
        "Wrap calls in try-catch",
        "Use onError callback",
        "Show user-friendly error messages"
      ],
      "recommendation": {
        "title": "Add error handling in caller",
        "description": "When calling procedures, handle errors properly.",
        "library": "tRPC"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "trpc\\.",
          "message": "tRPC usage detected"
        }
      ]
    }
  ]
}
