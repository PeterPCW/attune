      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "cleanliness",
      "recommendation": {
        "title": "Use structured logging",
        "description": "Use aiohttp-debugtoolbar or logging module.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "print\\s*\\("
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Use logging instead of print"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    }
  ]
}