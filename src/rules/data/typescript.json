    {
      "id": "TS_STRICT_NULL",
      "name": "Missing strict null checks",
      "category": "typescript",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "No strict null checks",
        "Null/undefined not handled",
        "Runtime errors"
      ],
      "fix": [
        "Enable strictNullChecks",
        "Handle null/undefined",
        "Use optional chaining"
      ],
      "recommendation": {
        "title": "Enable strictNullChecks",
        "description": "Enable strictNullChecks to handle null/undefined properly.",
        "library": "TypeScript"
      },
      "fileExtensions": [".ts", ".tsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "!\\?|!\\.|!== undefined",
          "message": "Non-null assertion used - consider handling null/undefined explicitly"
        }
      ]
    },
    {
      "id": "TS_UNUSED_VARS",
