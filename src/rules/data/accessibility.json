      ],
      "recommendation": {
        "title": "Add focus indicators",
        "description": "Interactive elements need visible focus indicators for keyboard users.",
        "library": "WCAG 2.1 AA2"
      },
      "helpers": [
        {
          "name": "findRemovedFocusIndicator",
          "params": {
            "message": "Focus indicator removed - keyboard users won't know which element is focused"
          }
        }
      ]
    },
    {
      "id": "ACCESS_FORM_LABEL",
      "name": "Form input missing label",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
