          "pattern": "useSearch|useNavigate|<Search|<SiteMap",
          "message": "Search or navigation component found"
        }
      ]
    },
    {
      "id": "A11Y_FOCUS_VISIBLE",
      "name": "Focus not visible",
      "category": "accessibility",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Focus indicator not visible",
        "Keyboard users lose track of focus",
        "WCAG focus visible violation"
      ],
      "fix": [
        "Ensure focus is always visible",
        "Don't hide focus with CSS",
        "Use high contrast focus styles"
      ],
      "recommendation": {
        "title": "Make focus clearly visible",
        "description": "Keyboard focus must have visible indicator at all times.",
