{
  "rules": [
    {
      "id": "NUXT_CONFIG_PUBLIC",
      "name": "Secrets in public config",
      "category": "security",
      "severity": "critical",
      "frameworks": ["nuxt"],
      "catches": [
        "API keys exposed to client",
        "Secrets leaked in browser",
        "Security vulnerabilities"
      ],
      "fix": [
        "Move secrets to runtimeConfig.private",
        "Access private config server-side only",
        "Never put secrets in public section"
      ],
      "recommendation": {
        "title": "Move secrets out of public config",
        "description": "Runtime config public keys are exposed to the client. Use private keys for secrets.",
        "library": "Nuxt"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "runtimeConfig[^}]*public",
          "message": "Runtime config with public section detected"
        }
      ]
    },
    {
      "id": "NUXT_SERVER_ROUTE_SYNC",
      "name": "Sync code in server route",
      "category": "architecture",
      "severity": "high",
      "frameworks": ["nuxt"],
      "catches": [
        "Blocking event loop",
        "Poor server performance",
        "Can't handle async operations"
      ],
      "fix": [
        "Use async/await in defineEventHandler",
        "Return promises from handlers",
        "Handle errors with try-catch"
      ],
      "recommendation": {
        "title": "Use async/await in server routes",
        "description": "Server routes should use async/await for proper error handling.",
        "library": "Nuxt"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "defineEventHandler",
          "message": "Server route handler detected"
        }
      ]
    }
  ]
}
