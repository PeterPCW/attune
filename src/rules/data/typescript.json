    {
      "id": "TS_OPTIONAL_PARAMS",
      "name": "Consider parameter ordering",
      "category": "typescript",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "Optional params before required",
        "Confusing API design",
        "TypeScript pattern suggestion"
      ],
      "fix": [
        "Reorder parameters",
        "Put required first",
        "Use optional at end"
      ],
      "recommendation": {
        "title": "Consider parameter ordering",
        "description": "Consider putting required parameters before optional ones for clearer APIs. This is a suggestion - ignore if intentional.",
        "library": "TypeScript"
      },
      "fileExtensions": [".ts", ".tsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "\\w+\\s*\\?\\s*:\\s*\\w+",
          "message": "Ternary with optional param pattern found"
        }
      ]
    },
    {
      "id": "TS_FS_PROMISES",
      "name": "Missing fs/promises import",
      "category": "typescript",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Using callback-based fs",
        "No async/await support",
        "Code complexity"
      ],
      "fix": [
        "Import from fs/promises",
        "Use async/await",
        "Simplify code"
      ],
      "recommendation": {
        "title": "Use fs/promises for async file operations",
        "description": "Import async functions from 'fs/promises' instead of 'fs'. The 'fs' module exports callback-based functions, not promises.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "import\\s+\\{[^}]*(?:readFile|readdir|stat|writeFile|mkdir|rm|readFileSync)[^}]*\\}\\s+from\\s+['\"]fs['\"]",
          "message": "Using callback-based fs functions - import from 'fs/promises' for async/await support",
          "fileExtensions": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx"
          ],
          "excludePatterns": [
            "node_modules/",
            "/rules/"
          ]
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
    {
      "id": "TS_SYNC_FS_ASYNC",
      "name": "Synchronous fs in async function",
      "category": "typescript",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Sync fs in async function",
        "Blocks event loop",
        "Poor performance"
      ],
      "fix": [
        "Use fs/promises",
        "Use async/await",
        "Don't block event loop"
      ],
      "recommendation": {
        "title": "Use async fs functions in async contexts",
        "description": "Synchronous fs operations (readFileSync, writeFileSync, etc.) block the event loop. Use async versions from fs/promises.",
        "library": "Node.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "async\\s+function[^}]*\\{[^}]*(?:readFileSync|writeFileSync|mkdirSync|rmSync|readdirSync|statSync|existsSync|copyFileSync|appendFileSync)\\s*\\(",
          "message": "Synchronous fs operation in async function - use fs/promises instead",
          "fileExtensions": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx"
          ],
          "excludePatterns": [
            "node_modules/"
          ]
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
    {
      "id": "TS_TYPEOF_SAFETY",
      "name": "Unsafe typeof comparison",
      "category": "typescript",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Unsafe typeof comparison",
        "Unreliable type checks",
        "Potential bugs"
      ],
      "fix": [
        "Use Array.isArray()",
        "Use instanceof",
        "Use strict equality"
      ],
      "recommendation": {
        "title": "Use proper type checking",
        "description": "typeof is unreliable for complex type checks. Use Array.isArray(), instanceof, or strict equality checks.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "typeof\\s+\\w+\\s*===?\\s*['\"](?:object|function)['\"]",
          "message": "typeof comparison for object/function is unreliable - use instanceof or Array.isArray()",
          "excludePatterns": [
            "node_modules/"
          ]
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
    {
      "id": "PERF_REGEX_LOOP",
      "name": "Regex created inside loop",
      "category": "performance",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Regex created in loop",
        "Repeated compilation",
        "Performance issues"
      ],
      "fix": [
        "Move regex outside loop",
        "Compile once",
        "Reuse regex"
      ],
      "recommendation": {
        "title": "Move regex outside loop",
        "description": "Creating new RegExp inside loops causes repeated compilation. Move outside and reuse.",
        "library": "Performance"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "(?:for|while|forEach|map|filter|reduce)\\s*\\([^}]*\\{[^}]*new\\s+RegExp",
          "message": "Regex created inside loop - move outside for better performance",
          "fileExtensions": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx"
          ],
          "excludePatterns": [
            "node_modules/"
          ]
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
