{
  "version": "1.0",
  "functions": [
    {
      "id": "K8S_NO_LIVENESS",
      "name": "Missing liveness probe",
      "description": "Liveness probes detect hung containers that need restart.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "kubernetes",
      "recommendation": {
        "title": "Add liveness probe",
        "description": "Liveness probes detect hung containers that need restart.",
        "library": "Kubernetes"
      },
      "catches": [
        "Hung containers not restarted",
        "No recovery mechanism",
        "App stuck in bad state"
      ],
      "fix": [
        "Add livenessProbe endpoint",
        "Configure initial delay",
        "Set failure threshold"
      ],
      "condition": {
        "type": "regex",
        "pattern": "livenessProbe|liveness",
        "fileExtensions": [
          "yaml",
          "yml"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Liveness probe found"
      },
      "projectTypes": []
    },
