{
  "rules": [
    {
      "id": "DEPS_NO_LOCKFILE",
      "name": "Missing lockfile",
      "category": "dependencies",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "No lockfile in project",
        "Inconsistent dependency versions",
        "Reproducibility issues"
      ],
      "fix": [
        "Generate package-lock.json",
        "Use yarn.lock or pnpm-lock.yaml",
        "Commit lockfile to repo"
      ],
      "recommendation": {
        "title": "Use lockfiles for reproducible builds",
        "description": "Lockfiles ensure consistent dependency versions across environments.",
        "library": "package-lock.json, yarn.lock"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "lockfileVersion",
          "message": "Lockfile detected - good",
          "fileExtensions": ["package!-lock.json", "yarn.lock", "pnpm-lock.yaml"]
        }
      ],
      "helpers": [
        {
          "name": "findOnLines",
          "params": {
            "pattern": "lockfileVersion",
            "message": "Lockfile missing - generate with npm install",
            "fileExtensions": ["package.json"],
            "skipPaths": ["node_modules"]
          }
        }
      ]
    },
    {
      "id": "DEPS_PRIVATE",
      "name": "Missing private field for private packages",
      "category": "dependencies",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No private field in package.json",
        "Risk of accidental publishing",
        "Exposes internal package"
      ],
      "fix": [
        "Add \"private\": true",
        "Prevent accidental publish",
        "Set in package.json"
      ],
      "recommendation": {
        "title": "Mark private packages as private",
        "description": "Set \"private\": true to prevent accidental publishing.",
        "library": "package.json"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\"private\"",
          "message": "Private field present",
          "fileExtensions": ["package.json"]
        }
      ]
    },
    {
      "id": "DEPS_NO_REPOS",
      "name": "Missing repository field",
      "category": "dependencies",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "No repository field",
        "Package not linked to source",
        "Hard to navigate"
      ],
      "fix": [
        "Add repository field",
        "Link to GitHub repo",
        "Help users find source"
      ],
      "recommendation": {
        "title": "Add repository field",
        "description": "Repository field links package to source code.",
        "library": "package.json"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\"repository\"",
          "message": "Repository field present",
          "fileExtensions": ["package.json"]
        }
      ]
    }
  ]
}
