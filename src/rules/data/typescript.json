{
  "rules": [
    {
      "id": "TS_ANY_USAGE",
      "name": "Using 'any' type",
      "category": "typescript",
      "severity": "medium",
      "frameworks": [],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ],
      "catches": [
        "Using 'any' type",
        "No type safety",
        "Defeats TypeScript purpose"
      ],
      "fix": [
        "Use specific types",
        "Use 'unknown' for dynamic",
        "Define interfaces"
      ],
      "recommendation": {
        "title": "Avoid using `any` type",
        "description": "Using `any` defeats TypeScript type safety. Use specific types or `unknown` if truly dynamic.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": ":\\s*any\\b",
          "message": "Using 'any' type - use specific type instead",
          "fileExtensions": [
            ".ts",
            ".tsx"
          ],
          "excludePatterns": [
            "/rules/"
          ]
        }
      ]
    },
    {
      "id": "TS_IMPLICIT_ANY",
      "name": "Implicit any in function params",
      "category": "typescript",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Implicit any in function params",
        "No type checking",
        "Runtime errors"
      ],
      "fix": [
        "Add explicit types",
        "Enable strict mode",
        "Fix parameter types"
      ],
      "recommendation": {
        "title": "Add type annotation for implicit any",
        "description": "Function parameters without type annotations default to `any`. Add explicit types.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "function\\s+\\w+\\s*\\(([^)]+)\\)",
          "message": "Function parameter without type annotation",
          "fileExtensions": [
            ".ts",
            ".tsx"
          ]
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
    {
      "id": "TS_OPTIONAL_CHAIN",
      "name": "Unsafe optional chaining depth",
      "category": "typescript",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Deep optional chaining",
        "Hard to reason about",
        "Potential runtime errors"
      ],
      "fix": [
        "Use early returns",
        "Restructure objects",
        "Add null checks"
      ],
      "recommendation": {
        "title": "Avoid unsafe optional chaining depth",
        "description": "Deep optional chaining can be hard to reason about. Consider explicit checks.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\\?\\.[^?]*\\?\\.[^?]*\\?\\.",
          "message": "Deep optional chaining detected - consider early return or object restructuring"
        }
      ],
      "fileExtensions": [
        ".ts",
        ".tsx"
      ]
    },
    {
      "id": "TS_TYPE_ASSERTION",
