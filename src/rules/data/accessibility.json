        "title": "Add labels to form inputs",
        "description": "Form inputs need associated labels for screen readers.",
        "library": "WCAG 2.1 A1"
      },
      "helpers": [
        {
          "name": "findMissingFormLabels",
          "params": {
            "message": "Form input missing label - screen reader users won't know what this field is for"
          }
        }
      ]
    },
    {
      "id": "A11Y_COGNITIVE_LOAD",
      "name": "Complex language may cause cognitive load",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Complex language and jargon",
        "Content hard to understand",
        "Cognitive accessibility issues"
      ],
      "fix": [
        "Use simple, clear language",
        "Avoid jargon when possible",
        "Break up complex content"
      ],
      "recommendation": {
        "title": "Use clear, simple language",
        "description": "Avoid complex sentences and jargon. Aim for reading level appropriate for audience.",
        "library": "WCAG 2.1 - Cognitive"
      },
      "patterns": [
        {
          "type": "regex",
