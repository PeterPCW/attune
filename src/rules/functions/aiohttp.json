    {
      "id": "AIOHTTP_STATIC_ROOT",
      "name": "Static files without proper cache headers",
      "description": "Add Cache-Control headers for static assets.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Configure cache headers",
        "description": "Add Cache-Control headers for static assets.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "StaticRoute\\|static\\.add_routes"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Add cache headers for static files"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_SESSION_CREATE",
      "name": "Creating ClientSession inside handler",
      "description": "Create ClientSession at app startup, close at shutdown.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Use application-scoped session",
        "description": "Create ClientSession at app startup, close at shutdown.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "async\\s+def\\s+\\w+.*:ClientSession\\(\\)"
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "ClientSession should be created once, not per request"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_DEBUG_TRUE",
      "name": "Debug mode in production",
      "description": "Set debug=False in production.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "security",
      "recommendation": {
        "title": "Disable debug in production",
        "description": "Set debug=False in production.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "web\\.run_app\\(debug\\s*=\\s*True"
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Debug mode should be disabled in production"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_NO_LOGGING",
      "name": "Not using structured logging",
