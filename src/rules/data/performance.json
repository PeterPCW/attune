    {
      "id": "PERF_TREE_SHAKING",
      "name": "Potential tree shaking issues",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No sideEffects config",
        "ES modules not used",
        "Unused code included"
      ],
      "fix": [
        "Add sideEffects: false",
        "Use ES modules",
        "Configure webpack/rollup"
      ],
      "recommendation": {
        "title": "Enable tree shaking",
        "description": "Ensure ES modules and sideEffects: false for better tree shaking.",
        "library": "Webpack, Rollup"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "sideEffects\\s*:\\s*false",
