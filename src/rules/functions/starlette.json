{
  "version": "1.0",
  "functions": [
    {
      "id": "STARLETTE_SYNC_IN_ASYNC",
      "name": "Synchronous blocking code in async endpoint",
      "description": "Use httpx or aiohttp instead of requests.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "starlette"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Use async HTTP client",
        "description": "Use httpx or aiohttp instead of requests.",
        "library": "Starlette"
      },
      "condition": {
        "type": "regex",
        "pattern": "async\\s+def\\s+\\w+.*:requests\\."
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Synchronous HTTP client in async function"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "STARLETTE_NO_PAGINATION",
      "name": "Missing pagination for list endpoints",
      "description": "Use offset/limit or cursor-based pagination.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "starlette"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Add pagination",
        "description": "Use offset/limit or cursor-based pagination.",
        "library": "Starlette"
      },
      "condition": {
        "type": "regex",
        "pattern": "@router\\.get\\(\""
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider adding pagination to list endpoints"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "STARLETTE_NO_DEPENDENCY_INJECTION",
      "name": "Not using dependency injection",
      "description": "Use Depends() to inject dependencies.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "starlette"
      ],
      "languages": [
        "python"
      ],
      "category": "architecture",
      "recommendation": {
        "title": "Use Depends() for dependencies",
        "description": "Use Depends() to inject dependencies.",
        "library": "Starlette"
      },
      "condition": {
        "type": "regex",
        "pattern": "async\\s+def\\s+\\w+\\(\\):(?!Depends)"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider using Depends() for dependency injection"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "STARLETTE_NO_RESPONSE_MODEL",
      "name": "Missing response_model",
      "description": "Use response_model parameter for type validation.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "starlette"
      ],
      "languages": [
        "python"
      ],
      "category": "api",
