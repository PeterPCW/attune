{
  "rules": [
    {
      "id": "GQL_SUB_NO_AUTH",
      "name": "GraphQL subscriptions not authenticated",
      "category": "graphql-subscriptions",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Unauthenticated connections",
        "Anyone can subscribe",
        "Security issues"
      ],
      "fix": [
        "Add auth to subscription resolvers",
        "Validate tokens on connection",
        "Check permissions"
      ],
      "recommendation": {
        "title": "Authenticate subscriptions",
        "description": "Subscriptions should require authentication like queries/mutations.",
        "library": "Apollo Server, graphql-ws"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "Subscription|@subscription",
          "message": "GraphQL subscription found - add auth",
          "fileExtensions": [".ts", ".js", ".graphql", ".gql"]
        }
      ]
    },
    {
      "id": "GQL_SUB_NO_RATE_LIMIT",
      "name": "GraphQL subscriptions missing rate limit",
      "category": "graphql-subscriptions",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Many concurrent connections",
        "Server overload",
        "Resource exhaustion"
      ],
      "fix": [
        "Add connection limits",
        "Throttle per user",
        "Monitor connections"
      ],
      "recommendation": {
        "title": "Limit subscription connections",
        "description": "Limit concurrent subscriptions per user to prevent abuse.",
        "library": "graphql-ws rate limit"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "subscription|onConnect",
          "message": "Subscription found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "GQL_SUB_NO_VALIDATION",
      "name": "Subscription payload not validated",
      "category": "graphql-subscriptions",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Invalid data processed",
        "No type safety",
        "Potential errors"
      ],
      "fix": [
        "Validate connection params",
        "Use schema validation",
        "Check payload data"
      ],
      "recommendation": {
        "title": "Validate subscription payloads",
        "description": "Validate connection params and payload data.",
        "library": "graphql-ws"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "validate|validation|schema",
          "message": "Validation found",
          "fileExtensions": [".ts", ".js", ".graphql", ".gql"]
        }
      ]
    }
  ]
}
