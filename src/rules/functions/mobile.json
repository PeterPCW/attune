    },
    {
      "id": "MOBILE_BATTERY_DRAIN",
      "name": "Background processes may drain battery",
      "description": "Avoid unnecessary background processing to preserve battery.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "performance",
      "recommendation": {
        "title": "Optimize background processes",
        "description": "Avoid unnecessary background processing to preserve battery.",
        "library": "Performance"
      },
      "catches": [
        "Battery drains quickly",
        "Background timers running unnecessarily",
        "Poor battery life experience"
      ],
      "fix": [
        "Use Page Visibility API",
        "Pause animations when hidden",
