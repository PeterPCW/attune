{
  "rules": [
    {
      "id": "ASTRO_CLIENT_LOAD",
      "name": "Hydrating everything",
      "category": "performance",
      "severity": "low",
      "frameworks": ["astro"],
      "catches": [
        "Unnecessary client hydration",
        "Larger bundle size",
        "Slower initial load"
      ],
      "fix": [
        "Use client directives only when needed",
        "Avoid client:load on static content",
        "Use client:visible for below-fold content"
      ],
      "recommendation": {
        "title": "Use client directives only when needed",
        "description": "Only hydrate components that need interactivity. Avoid client:load on static content.",
        "library": "Astro"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "client:",
          "message": "Client directive detected - use only when needed"
        }
      ]
    },
    {
      "id": "ASTRO_NO_PRERENDER",
      "name": "Missing prerender",
      "category": "performance",
      "severity": "medium",
      "frameworks": ["astro"],
      "catches": [
        "Static pages not prerendered",
        "Server-side rendering on each request",
        "Wasted resources"
      ],
      "fix": [
        "Add prerender to static pages",
        "Use static adapter",
        "Pre-generate pages at build time"
      ],
      "recommendation": {
        "title": "Add prerender for static pages",
        "description": "Static pages should use prerender for better performance.",
        "library": "Astro"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "export\\s+const\\s+prerender\\s*=\\s*true",
          "message": "Page with prerender enabled for static generation"
        }
      ]
    },
    {
      "id": "ASTRO_DIRECTIVE_WRONG",
      "name": "Wrong hydration directive",
      "category": "performance",
      "severity": "medium",
      "frameworks": ["astro"],
      "catches": [
        "Wrong hydration directive used",
        "Inefficient loading",
        "Poor performance"
      ],
      "fix": [
        "Use client:visible for below-fold content",
        "Use client:idle for non-critical",
        "Use client:load only for above-fold"
      ],
      "recommendation": {
        "title": "Use correct hydration directive",
        "description": "Choose appropriate directive: client:load, client:visible, client:idle, etc.",
        "library": "Astro"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "client:load",
          "message": "Using client:load - consider client:visible or client:idle for better performance"
        }
      ]
    }
  ]
}
