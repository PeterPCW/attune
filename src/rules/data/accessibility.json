{
  "rules": [
    {
      "id": "ACCESS_SKIP_LINK",
      "name": "Missing skip link",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "No skip navigation link",
        "Keyboard users can't bypass navigation",
        "WCAG 2.1 B1 violation"
      ],
      "fix": [
        "Add a skip link at the top of the page",
        "Make it visible on focus",
        "Link to the main content area"
      ],
      "recommendation": {
        "title": "Add skip navigation link",
        "description": "Add a skip link to allow keyboard users to bypass navigation.",
        "library": "WCAG 2.1 B1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "skip.?link|<a[^>]+href=\"#",
          "message": "Skip link found",
          "fileExtensions": [".html", ".tsx", ".jsx", ".vue", ".svelte", ".astro"]
        }
      ]
    },
    {
      "id": "ACCESS_LANG_ATTRIBUTE",
      "name": "Missing lang attribute",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Missing lang attribute on HTML element",
        "Screen readers can't pronounce content correctly",
        "WCAG 2.1 A3 violation"
      ],
      "fix": [
        "Add lang attribute to <html> tag (e.g., lang=\"en\")",
        "Use appropriate language code for the content"
      ],
      "recommendation": {
        "title": "Add lang attribute to HTML",
        "description": "Add lang attribute to the html element for screen readers.",
        "library": "WCAG 2.1 A3"
      },
      "helpers": [
        {
          "name": "findMissingLang",
          "params": {
            "message": "HTML missing lang attribute - screen readers need this to pronounce correctly"
          }
        }
      ]
    },
    {
      "id": "ACCESS_KBD_NAV",
      "name": "Keyboard navigation issues",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Interactive elements not keyboard accessible",
        "Users can't navigate with Tab key",
        "WCAG 2.1 A2 violation"
      ],
      "fix": [
        "Ensure all buttons/links are focusable",
        "Add keyboard event handlers",
        "Test with keyboard only navigation"
      ],
      "recommendation": {
        "title": "Ensure keyboard accessibility",
        "description": "All interactive elements must be keyboard accessible.",
        "library": "WCAG 2.1 A2"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "tabIndex|keydown|keypress|onKey",
          "message": "Keyboard accessibility found"
        }
      ]
    },
    {
      "id": "ACCESS_LIVE_REGION",
      "name": "Missing live region for dynamic content",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Dynamic content updates not announced",
        "Screen reader users miss updates",
        "WCAG 2.1 A1 violation"
      ],
      "fix": [
        "Add aria-live attribute to dynamic content regions",
        "Use polite or assertive based on urgency"
      ],
      "recommendation": {
        "title": "Add live regions for dynamic content",
        "description": "Use aria-live for content that updates dynamically.",
        "library": "WCAG 2.1 A1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "aria-live",
          "message": "ARIA live region found"
        }
      ]
    },
    {
      "id": "A11Y_REDUCED_MOTION",
      "name": "Missing reduced motion preference",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Animations play for users who prefer reduced motion",
        "Can cause dizziness or nausea",
        "WCAG 2.1 A2 violation"
      ],
      "fix": [
        "Add prefers-reduced-motion media query",
        "Disable or reduce animations for users who prefer it"
      ],
      "recommendation": {
        "title": "Respect reduced motion preference",
        "description": "Add media query for prefers-reduced-motion.",
        "library": "WCAG 2.1 A2"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "prefers-reduced-motion",
          "message": "Reduced motion support found"
        }
      ]
    },
    {
      "id": "A11Y_TIMEOUT_SHORT",
      "name": "Short timeout without warning",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Users timed out without warning",
        "Data loss from expired sessions",
        "WCAG 2.1 A1 violation"
      ],
      "fix": [
        "Warn users before timeout",
        "Provide ways to extend session",
        "Allow users to adjust timeout settings"
      ],
      "recommendation": {
        "title": "Warn users of short timeouts",
        "description": "Sessions with short timeouts should warn users.",
        "library": "WCAG 2.1 A1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "setTimeout|timeout|expiry|session",
          "message": "Timeout handling found"
        }
      ]
    },
    {
      "id": "A11Y_ERROR_UNCLEAR",
      "name": "Unclear error messages",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Error messages not descriptive",
        "Users don't know how to fix errors",
        "WCAG 2.1 A1 violation"
      ],
      "fix": [
        "Write clear, specific error messages",
        "Explain what went wrong and how to fix it",
        "Use plain language"
      ],
      "recommendation": {
        "title": "Make error messages clear",
        "description": "Error messages should clearly explain what went wrong.",
        "library": "WCAG 2.1 A1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "error|Error|message|validation",
          "message": "Error handling found"
        }
      ]
    },
    {
      "id": "ACCESS_HEADING_ORDER",
      "name": "Heading level skipped",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Heading levels skipped (e.g., h1 to h3)",
        "Screen reader users can't navigate structure",
        "WCAG 2.1 A1 violation"
      ],
      "fix": [
        "Use sequential heading levels",
        "Don't skip from h1 to h3 without h2",
        "Use proper hierarchy for outline"
      ],
      "recommendation": {
        "title": "Maintain proper heading hierarchy",
        "description": "Heading levels should not skip (e.g., h1 to h3 without h2).",
        "library": "WCAG 2.1 A1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "<h[1-6][^>]*>",
          "message": "Heading elements found"
        }
      ]
    },
    {
      "id": "ACCESS_IMG_ALT",
      "name": "Image missing alt text",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Image missing alt attribute",
        "Screen readers can't describe images",
        "WCAG 2.1 A1 violation"
      ],
      "fix": [
        "Add alt text to all images",
        "Use alt=\"\" for decorative images",
        "Describe image content in alt text"
      ],
      "recommendation": {
        "title": "Add alt text to images",
        "description": "Images need alt text for screen readers. Use empty alt=\"\" for decorative images.",
        "library": "WCAG 2.1 A1"
      },
      "helpers": [
        {
          "name": "findMissingAltText",
          "params": {
            "message": "Image missing alt attribute - screen readers cannot describe this image"
          }
        }
      ]
    },
    {
      "id": "ACCESS_ARIA_LABEL",
      "name": "Missing ARIA labels",
      "category": "accessibility",
      "severity": "high",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Buttons/links without accessible names",
        "Screen readers can't describe elements",
        "WCAG 2.1 A4 violation"
      ],
      "fix": [
        "Add aria-label to interactive elements",
        "Use aria-labelledby for complex labels",
        "Ensure icon buttons have labels"
      ],
      "recommendation": {
        "title": "Add ARIA labels to interactive elements",
        "description": "Buttons and links need accessible names. Use aria-label or aria-labelledby.",
        "library": "WCAG 2.1 A4"
      },
      "helpers": [
        {
          "name": "findUnlabeledButtons",
          "params": {
            "message": "Button may lack accessible name"
          }
        }
      ]
    },
    {
      "id": "ACCESS_LINK_TEXT",
      "name": "Insufficient link text",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Link text not descriptive (e.g., click here)",
        "Users can't determine link destination",
        "WCAG 2.1 A13 violation"
      ],
      "fix": [
        "Use descriptive link text",
        "Avoid generic phrases like click here",
        "Make link purpose clear"
      ],
      "recommendation": {
        "title": "Use descriptive link text",
        "description": "Links should describe their destination. Avoid \"click here\" or \"read more\".",
        "library": "WCAG 2.1 A13"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "<a[^>]*>(click here|read more|here|link)</a>",
          "message": "Link text not descriptive"
        }
      ]
    },
    {
      "id": "ACCESS_COLOR_CONTRAST",
      "name": "Potential color contrast issue",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": ["react", "vue", "nextjs", "nuxt", "astro", "svelte", "angular"],
      "catches": [
        "Insufficient color contrast",
        "Text hard to read for visually impaired users",
        "WCAG 2.1 AA1 violation"
      ],
      "fix": [
        "Ensure 4.5:1 contrast ratio for normal text",
        "Ensure 3:1 for large text",
        "Use contrast checker tools"
      ],
      "recommendation": {
        "title": "Ensure sufficient color contrast",
        "description": "Text should have 4.5:1 contrast ratio against background.",
        "library": "WCAG 2.1 AA1"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "contrast|color|background|foreground",
          "message": "Color contrast handling found"
        }
      ]
    },
    {
      "id": "ACCESS_FOCUS_INDICATOR",
      "name": "Missing focus indicators",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Focus indicator removed or hidden",
        "Keyboard users can't see focused element",
        "WCAG 2.1 AA2 violation"
      ],
      "fix": [
        "Ensure focus indicators are visible",
        "Don't remove outline without replacement",
