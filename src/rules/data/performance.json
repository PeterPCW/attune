{
  "rules": [
    {
      "id": "PERF_BIG_BUNDLE",
      "name": "Large bundle size",
      "category": "performance",
      "severity": "medium",
      "frameworks": ["react", "nextjs", "vue", "svelte"],
      "catches": [
        "Large JavaScript bundles",
        "No code splitting",
        "Slow initial load times"
      ],
      "fix": [
        "Use dynamic imports",
        "Implement code splitting",
        "Analyze bundle with source-map-explorer"
      ],
      "recommendation": {
        "title": "Code splitting for large bundles",
        "description": "Large bundles hurt load time. Use dynamic imports for code splitting.",
        "library": "Webpack, Vite"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "lazy|dynamic|import\\(|code.?split|lazyload",
          "message": "Code splitting found"
        }
      ]
    },
    {
      "id": "PERF_SYNCHRONOUS",
      "name": "Synchronous file operations",
      "category": "performance",
      "severity": "medium",
      "frameworks": ["nodejs", "express", "fastify"],
      "catches": [
        "readFileSync usage",
        "writeFileSync usage",
        "Blocking the event loop"
      ],
      "fix": [
        "Use async/await versions",
        "Use fs.promises",
        "Never block in Node.js"
      ],
      "recommendation": {
        "title": "Avoid synchronous operations",
        "description": "Use async/await for I/O operations to avoid blocking.",
        "library": "Node.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "readFileSync",
          "message": "Synchronous file read - use async version instead"
        },
        {
          "type": "regex",
          "pattern": "writeFileSync",
          "message": "Synchronous file write - use async version instead"
        },
        {
          "type": "regex",
          "pattern": "existsSync",
          "message": "Synchronous exists check - use async version instead"
        }
      ]
    },
    {
      "id": "PERF_MEMORY_LEAK",
      "name": "Potential memory leak",
      "category": "performance",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Global variable usage",
        "Unbounded arrays",
        "Missing cleanup"
      ],
      "fix": [
        "Avoid global variables",
        "Clean up event listeners",
        "Clear intervals/timeouts"
      ],
      "recommendation": {
        "title": "Check for potential memory leaks",
        "description": "Global variables and uncached arrays can cause memory leaks.",
        "library": "Node.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "global\\.",
          "message": "Global variable mutation - can cause memory leaks"
        },
        {
          "type": "regex",
          "pattern": "globalThis\\.",
          "message": "Global variable mutation - can cause memory leaks"
        }
      ]
    },
    {
      "id": "PERF_IMMUTABLE",
      "name": "Mutable object mutation",
      "category": "performance",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Array.push() mutations",
        "Object mutations",
        "Side effects"
      ],
      "fix": [
        "Use spread operator",
        "Use Immer for immutable updates",
        "Prefer const over let"
      ],
      "recommendation": {
        "title": "Prefer immutability",
        "description": "Mutating objects creates side effects. Use immutable patterns.",
        "library": "Immer, immutable.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\\.push\\s*\\(",
          "message": "Array mutation detected - consider immutable patterns"
        },
        {
          "type": "regex",
          "pattern": "\\.splice\\s*\\(",
          "message": "Array mutation detected - consider immutable patterns"
        }
      ]
    },
    {
      "id": "PERF_REGEX",
      "name": "Inefficient regex in loop",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Regex created inside loops",
        "Inefficient pattern matching",
        "Performance degradation"
      ],
      "fix": [
        "Move regex outside loops",
        "Compile regex once",
        "Use regex literals"
      ],
      "recommendation": {
        "title": "Optimize regex patterns",
        "description": "Inefficient regex can slow down execution. Compile regexes outside loops.",
        "library": "Performance"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "new RegExp|RegExp\\(",
          "message": "Regex outside loop found"
        }
      ]
    },
    {
      "id": "PERF_CACHING",
      "name": "Missing caching for expensive operations",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No caching implemented",
        "Repeated expensive calls",
        "Database hits every request"
      ],
      "fix": [
        "Add memoization",
        "Use Redis for distributed caching",
        "Cache expensive computations"
      ],
      "recommendation": {
        "title": "Add caching for expensive operations",
        "description": "Expensive operations should be cached.",
        "library": "Performance"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "cache|memo|redis|Map\\(|Set\\(",
          "message": "Caching found"
        }
      ]
    },
    {
      "id": "PERF_DEBOUNCE",
      "name": "Undebounced event handler",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Events firing too often",
        "No debounce on scroll/resize",
        "Excessive handler calls"
      ],
      "fix": [
        "Add lodash debounce",
        "Throttle frequent events",
        "Use useDebouncedCallback"
      ],
      "recommendation": {
        "title": "Debounce frequent events",
        "description": "Frequent events like scroll/resize should be debounced.",
        "library": "lodash.debounce"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "addEventListener",
          "message": "Event listener detected"
        }
      ]
    },
    {
      "id": "PERF_IMAGES",
      "name": "Unoptimized images",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Large image files",
        "No lazy loading",
        "Missing image optimization"
      ],
      "fix": [
        "Use next/image",
        "Add lazy loading",
        "Compress images"
      ],
      "recommendation": {
        "title": "Optimize images",
        "description": "Images should be optimized and lazy loaded.",
        "library": "next/image, vite-imagetools"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "Image|img|lazy|loading",
          "message": "Image optimization found"
        }
      ]
    },
    {
      "id": "PERF_LIST_VIRTUALIZATION",
      "name": "Long list without virtualization",
      "category": "performance",
      "severity": "medium",
      "frameworks": ["react", "vue", "svelte", "angular"],
      "catches": [
        "Rendering thousands of items",
        "No list virtualization",
        "Slow scrolling"
      ],
      "fix": [
        "Use react-window",
        "Virtualize large lists",
        "Only render visible items"
      ],
      "recommendation": {
        "title": "Virtualize long lists",
        "description": "Long lists should use virtualization for performance.",
        "library": "react-window, vue-virtual-scroller"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\\.map\\s*\\(",
          "message": "Consider virtualizing large lists with .map()",
          "fileExtensions": [".tsx", ".jsx", ".vue", ".svelte"],
          "excludePatterns": ["react-window", "vue-virtual-scroller", "useVirtualizer", "FixedSizeList", "VariableSizeList", "react-virtual", "virtual-scroller", "RecycleScroller"]
        }
      ]
    },
    {
      "id": "PERF_PRELOAD",
      "name": "Missing resource preload",
      "category": "performance",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "No resource preloading",
        "Delayed critical resources",
        "Suboptimal loading"
      ],
      "fix": [
        "Add preload links",
        "Prefetch critical assets",
        "Use link rel=preload"
      ],
      "recommendation": {
        "title": "Preload critical resources",
        "description": "Critical resources should be preloaded.",
        "library": "HTML preload"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "preload|prefetch|link.*rel.*preload",
          "message": "Resource preload found"
        }
      ]
    },
    {
      "id": "PERF_WEB_WORKER",
      "name": "Heavy computation on main thread",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Heavy computation blocking UI",
        "No web workers",
        "Janky animations"
      ],
      "fix": [
        "Move to web worker",
        "Use_comlink or similar",
        "Offload heavy tasks"
      ],
      "recommendation": {
        "title": "Offload to web worker",
        "description": "Heavy computations should be moved to web workers.",
        "library": "Web Workers"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "Worker|worker|postMessage",
          "message": "Web worker found"
        }
      ]
    },
    {
      "id": "PERF_DEPENDENCIES",
      "name": "Heavy dependency detected",
      "category": "performance",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Large dependencies",
        "Bundle bloat",
        "Slow installs"
      ],
      "fix": [
        "Check bundlephobia",
        "Use lighter alternatives",
