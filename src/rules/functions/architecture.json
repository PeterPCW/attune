{
  "version": "1.0",
  "functions": [
    {
      "id": "ARCH_CIRCULAR_DEP",
      "name": "Relative imports or barrel exports detected",
      "description": "Relative imports and barrel exports (index.ts re-exports) are common patterns. Only investigate if you're experiencing actual circular dependency issues. True circular dependencies involve A importing B which imports A.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "architecture",
      "recommendation": {
        "title": "Review imports for actual circular dependencies",
        "description": "Relative imports and barrel exports (index.ts re-exports) are common patterns. Only investigate if you're experiencing actual circular dependency issues. True circular dependencies involve A importing B which imports A.",
        "library": "Architecture"
      },
      "catches": [
        "Relative imports",
        "Barrel exports (index.ts re-exports)"
      ],
      "fix": [
        "This is often normal code organization - barrel exports are a standard pattern",
        "Only investigate if actual circular dependency issues arise"
      ],
      "condition": {
        "type": "regex",
        "pattern": "export\\s+\\{[X]\\}\\s+from\\s+['\"]\\.\\/[X]['\"]",
        "fileExtensions": [
          ".ts",
          ".js"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "info",
        "message": "Relative import or barrel export found"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "ARCH_HUB_MODULE",
      "name": "Hub module with too many dependencies",
      "description": "Modules that depend on too many other modules indicate poor separation. Split into smaller modules.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "architecture",
      "recommendation": {
        "title": "Split hub modules",
        "description": "Modules that depend on too many other modules indicate poor separation. Split into smaller modules.",
        "library": "Architecture"
      },
      "catches": [
        "Module depends on many others",
        "Poor separation of concerns",
        "Hard to maintain"
      ],
      "fix": [
        "Split into smaller modules",
        "Extract related functionality",
        "Reduce dependencies"
      ],
      "condition": {
        "type": "regex",
        "pattern": "services?|repositories?|controllers?|handlers?"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Layered structure found"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "ARCH_ORPHAN_MODULE",
      "name": "Orphan/unused module",
      "description": "Modules with no dependencies may be dead code. Verify and remove.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "architecture",
      "recommendation": {
        "title": "Remove orphan modules",
        "description": "Modules with no dependencies may be dead code. Verify and remove.",
        "library": "Architecture"
      },
      "catches": [
        "Orphan module with no dependencies",
        "May be dead code",
        "Unnecessary bundle size"
      ],
      "fix": [
        "Verify if module is used",
        "Remove dead code",
        "Add exports if needed"
      ],
      "condition": {
        "type": "regex",
        "pattern": "services?|repositories?|controllers?|handlers?"
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Layered structure found"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "ARCH_DB_IN_CONTROLLER",
      "name": "Database access in controller",
      "description": "Controllers should only handle HTTP concerns. Move database logic to repositories/services.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "express",
        "fastify",
        "nodejs"
      ],
      "category": "architecture",
      "recommendation": {
        "title": "Move database logic to service layer",
        "description": "Controllers should only handle HTTP concerns. Move database logic to repositories/services.",
        "library": "Layered Architecture"
      },
      "catches": [
        "Database logic in controller",
        "Poor separation of concerns",
        "Hard to test"
      ],
      "fix": [
        "Move DB logic to service/repository",
        "Keep controllers thin",
        "Separate HTTP and data concerns"
      ],
      "condition": {
        "type": "regex",
        "pattern": "prisma|drizzle|knex|query|sql"
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Database layer found"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
