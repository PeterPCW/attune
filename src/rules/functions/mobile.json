      },
      "projectTypes": [
        "mobile",
        "desktop"
      ]
    },
    {
      "id": "MOBILE_DEEP_LINK",
      "name": "No deep linking support",
      "description": "Support deep links to specific app screens from external URLs.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "react-native",
        "flutter"
      ],
      "category": "usability",
      "recommendation": {
