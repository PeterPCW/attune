      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "@\\w+\\(|export\\s+@",
          "message": "Decorator usage found",
          "fileExtensions": [".ts"]
        }
      ]
    },
    {
      "id": "PERF_EXPENSIVE_RENDER",
