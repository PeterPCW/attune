      "fix": [
        "Add discriminant property",
        "Use discriminated unions",
        "Improve type narrowing"
      ],
      "recommendation": {
        "title": "Use discriminated unions",
        "description": "Use discriminated unions for better type safety.",
        "library": "TypeScript"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "type\\s+\\w+\\s*=\\s*\\w+\\s*\\|",
