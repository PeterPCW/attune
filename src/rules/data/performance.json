      ],
      "recommendation": {
        "title": "Check for heavy dependencies",
        "description": "Heavy dependencies impact bundle size. Consider alternatives.",
        "library": "Bundle analysis"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "webpack|bundlephobia|rollup",
          "message": "Bundle tool found",
          "fileExtensions": [".json", ".js"]
        }
      ]
    },
    {
      "id": "PERF_SERVER_IMPORTS",
      "name": "Server-only imports in client code",
      "category": "performance",
      "severity": "high",
      "frameworks": ["nextjs"],
      "catches": [
        "Server code in client bundle",
        "Prisma in client",
        "Increased bundle size"
      ],
      "fix": [
        "Use 'server only' directive",
        "Keep server code in /app or /pages/api",
        "Use dynamic imports for server modules"
      ],
      "recommendation": {
        "title": "Remove server-only imports from client",
        "description": "Server-only modules should not be imported in client code.",
        "library": "Next.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "from\\s+['\"]\\.\\/server|getStaticProps|getServerSideProps|prisma\\/client",
          "message": "Server-only import found",
          "fileExtensions": [".ts", ".tsx", ".js", ".jsx"]
        }
      ]
    },
    {
      "id": "PERF_CLASS_DECORATOR",
      "name": "Class decorator impact",
      "category": "performance",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Decorator overhead",
        "Reflection usage",
        "Runtime metadata"
      ],
      "fix": [
        "Minimize decorator usage",
