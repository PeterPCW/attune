    {
      "id": "MOBILE_NOTCH_IGNORE",
      "name": "Notch/safe area not handled",
      "description": "Use env(safe-area-inset-*) for notches and system UI.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
