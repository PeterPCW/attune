    },
    {
      "id": "A11Y_NO_REFERRER",
      "name": "Link behavior changes context unexpectedly",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Links open new windows without warning",
        "Context changes unexpectedly on focus",
        "WCAG on focus violation"
      ],
      "fix": [
        "Warn before opening new window",
        "Use rel=\"noopener noreferrer\"",
        "Announce link behavior to screen readers"
      ],
      "recommendation": {
        "title": "Don't change context unexpectedly",
        "description": "Links should not open new windows/tabs without warning.",
        "library": "WCAG 2.1 - On Focus"
      },
      "fileExtensions": [".tsx", ".jsx", ".html"],
      "patterns": [
        {
