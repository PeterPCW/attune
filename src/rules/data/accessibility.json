        }
      ]
    },
    {
      "id": "A11Y_PREDICTABLE",
      "name": "Unpredictable behavior on focus/hover",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Focus/hover causes unexpected changes",
        "Content changes without user action",
        "WCAG predictability violation"
      ],
      "fix": [
        "Don't change content on focus/hover alone",
        "Use user-triggered events",
        "Provide controls for dynamic content"
      ],
      "recommendation": {
        "title": "Make behavior predictable",
        "description": "Focus and hover should not cause unexpected content changes.",
        "library": "WCAG 2.1 - Predictable"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "onFocus|onMouseEnter|onMouseLeave|hover|focus",
          "message": "Focus/hover handling found"
        }
      ]
    },
    {
      "id": "A11Y_ERROR_PREVENTION",
      "name": "No error prevention for forms",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No confirmation for important actions",
        "Users can't reverse submissions",
        "WCAG error prevention violation"
      ],
      "fix": [
        "Add confirmation dialogs for important actions",
        "Provide reversible submission options",
        "Allow undo functionality"
      ],
      "recommendation": {
        "title": "Add error prevention",
        "description": "Provide confirmation for important actions and reversible submissions.",
        "library": "WCAG 2.1 - Error Prevention"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "confirm|confirmDialog|confirmSubmit",
          "message": "Error prevention found"
        }
      ]
    },
    {
      "id": "A11Y_HELP_DOCS",
      "name": "Missing help or instructions",
      "category": "accessibility",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "No help text for complex forms",
        "Users don't understand required input",
        "WCAG input assistance violation"
      ],
      "fix": [
        "Add help text for complex fields",
        "Provide clear instructions",
        "Show examples where helpful"
      ],
      "recommendation": {
        "title": "Add help and instructions",
        "description": "Provide help text and clear instructions for complex forms.",
        "library": "WCAG 2.1 - Input Assistance"
      },
      "fileExtensions": [".tsx", ".jsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "<Input|<Select|<Textarea(?!.*help|.*description)",
          "message": "Form input without help text or description"
        }
      ]
    },
    {
      "id": "A11Y_FOCUS_ORDER",
      "name": "Focus order not logical",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Focus order doesn't follow visual layout",
        "Confusing navigation for keyboard users",
        "WCAG focus order violation"
      ],
      "fix": [
        "Order elements in DOM logically",
        "Use tabindex carefully",
        "Test with keyboard navigation"
      ],
      "recommendation": {
        "title": "Ensure logical focus order",
        "description": "Tab order should follow visual layout from left to right, top to bottom.",
        "library": "WCAG 2.1 - Focus Order"
      },
      "fileExtensions": [".tsx", ".jsx", ".html"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "tabindex\\s*=\\s*['\"][1-9][^0-9]",
          "message": "Manual tabindex found - may disrupt natural focus order"
        }
      ]
    },
    {
      "id": "A11Y_PAGE_TITLE",
      "name": "Missing or unclear page title",
      "category": "accessibility",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Missing or generic page title",
        "Users can't identify pages",
        "WCAG page titled violation"
      ],
      "fix": [
        "Add unique title to each page",
        "Include page name and site name",
        "Make titles descriptive"
      ],
      "recommendation": {
        "title": "Add descriptive page titles",
        "description": "Each page should have a unique, descriptive title.",
        "library": "WCAG 2.1 - Page Titled"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "<title>",
          "message": "Page title found"
        }
      ]
    },
    {
      "id": "A11Y_LANDMARKS",
      "name": "Missing semantic landmarks",
      "category": "accessibility",
      "severity": "medium",
