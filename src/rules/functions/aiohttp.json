{
  "version": "1.0",
  "functions": [
    {
      "id": "AIOHTTP_SYNC_DB",
      "name": "Synchronous database in aiohttp handler",
      "description": "Use asyncpg, aiomysql, or aiosqlite instead.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Use async database drivers",
        "description": "Use asyncpg, aiomysql, or aiosqlite instead.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "async\\s+def\\s+.*handler.*:(?:psycopg2|mysql|sqlite3)\\."
      },
      "action": {
        "type": "flag",
        "severity": "high",
        "message": "Synchronous database driver in async handler"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_NO_CORS",
      "name": "Missing CORS configuration",
      "description": "Use aiohttp.CorsMiddleware or aiohttp-security.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "security",
      "recommendation": {
        "title": "Configure CORS middleware",
        "description": "Use aiohttp.CorsMiddleware or aiohttp-security.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "web\\.Application\\(\\)"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Missing CORS middleware"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_NO_ERROR_HANDLER",
      "name": "Missing custom error handlers",
      "description": "Use app.router.register_error_handler() for custom errors.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "error-handling",
      "recommendation": {
        "title": "Add exception handlers",
        "description": "Use app.router.register_error_handler() for custom errors.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "web\\.Application\\(\\)"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider adding exception handlers"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_STREAMING",
      "name": "Not using streaming for large responses",
      "description": "Use web.StreamResponse for large files.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Use streaming responses",
        "description": "Use web.StreamResponse for large files.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "return\\s+web\\.Response\\("
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider streaming for large responses"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_TIMEOUT",
      "name": "Missing timeout for HTTP requests",
      "description": "Use aiohttp.ClientTimeout for all requests.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "reliability",
      "recommendation": {
        "title": "Configure timeouts",
        "description": "Use aiohttp.ClientTimeout for all requests.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "aiohttp\\.ClientSession\\(\\)"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider adding timeout configuration"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "AIOHTTP_NO_GZIP",
