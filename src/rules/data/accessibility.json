          "message": "HTML text element found",
          "fileExtensions": [".html", ".jsx", ".tsx", ".vue", ".svelte"]
        }
      ]
    },
    {
      "id": "A11Y_CONSISTENT_NAV",
      "name": "Inconsistent navigation across pages",
      "category": "accessibility",
      "severity": "medium",
      "frameworks": [],
      "catches": [
