{
  "rules": [
    {
      "id": "GRAPHQL_N_PLUS_ONE",
      "name": "GraphQL N+1 query problem",
      "category": "graphql",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "N+1 query in GraphQL resolvers",
        "Multiple database calls for related data",
        "Performance issues"
      ],
      "fix": [
        "Use DataLoader for batching",
        "Batch database queries",
        "Optimize resolvers"
      ],
      "recommendation": {
        "title": "Use DataLoader for batch queries",
        "description": "N+1 queries occur when resolvers fetch related data individually. Use DataLoader to batch requests.",
        "library": "dataloader"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "type.*\\{[^}]*\\[",
          "message": "Array field in GraphQL type - check for N+1",
          "fileExtensions": [".graphql", ".gql", ".ts", ".js"]
        }
      ]
    },
    {
      "id": "GRAPHQL_QUERY_DEPTH",
      "name": "Missing query depth limiting",
      "category": "graphql",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No query depth limiting",
        "DoS via deep queries",
        "Server overload risk"
      ],
      "fix": [
        "Add graphql-depth-limit",
        "Set max depth",
        "Block expensive queries"
      ],
      "recommendation": {
        "title": "Add query depth limiting",
        "description": "Unlimited query depth can cause denial of service. Add max depth validation.",
        "library": "graphql-depth-limit"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "graphql|apollo|nexus",
          "message": "GraphQL server found - consider depth limiting",
          "fileExtensions": [".ts", ".js", ".json"]
        }
      ]
    },
    {
      "id": "GRAPHQL_NO_CACHING",
      "name": "Missing GraphQL response caching",
      "category": "graphql",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No response caching",
        "Repeated queries hit database",
        "Server overload"
      ],
      "fix": [
        "Add response caching",
        "Use Redis cache",
        "Cache query results"
      ],
      "recommendation": {
        "title": "Add response caching",
        "description": "GraphQL queries can benefit from caching to reduce server load.",
        "library": "apollo-server-cache-redis"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "Query\\s*\\{",
          "message": "GraphQL Query type found - consider caching",
          "fileExtensions": [".graphql", ".gql", ".ts"]
        }
      ]
    },
    {
      "id": "GRAPHQL_INTROSPECTION_PROD",
      "name": "GraphQL introspection enabled in production",
      "category": "graphql",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Introspection enabled in production",
        "Schema exposed publicly",
        "Security risk"
      ],
      "fix": [
        "Disable introspection in production",
        "Use environment variable",
        "Limit to development"
      ],
      "recommendation": {
        "title": "Disable introspection in production",
        "description": "Disable GraphQL introspection in production to prevent schema exposure.",
        "library": "Apollo Server"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "introspection.*true|enableIntrospection",
          "message": "GraphQL introspection enabled",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "GRAPHQL_NO_VARIABLES",
      "name": "Query variables not used",
      "category": "graphql",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Hardcoded values in queries",
        "Reduced cacheability",
        "Potential injection"
      ],
      "fix": [
        "Use query variables",
        "Parameterize queries",
        "Improve caching"
      ],
      "recommendation": {
        "title": "Use query variables",
        "description": "Hardcoded values in queries reduce cacheability and allow injection.",
        "library": "GraphQL"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "query\\s+\\w+\\s*\\{[^}]*\\w+:\\s*[\"']",
          "message": "Hardcoded value in query - use variables",
          "fileExtensions": [".graphql", ".gql", ".ts"]
        }
      ]
    },
    {
      "id": "GRAPHQL_MUTATION_RETURN",
      "name": "Mutation without payload type",
      "category": "graphql",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Mutation returns scalar",
        "No structured response",
        "Hard to extend"
      ],
      "fix": [
        "Use payload types",
        "Return user, success, errors",
        "Improve type safety"
      ],
      "recommendation": {
        "title": "Use payload types for mutations",
        "description": "Return structured payload types from mutations for better type safety.",
        "library": "GraphQL"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "type\\s+\\w+Mutation\\s*=\\s*>",
          "message": "Mutation returns scalar - use payload type",
          "fileExtensions": [".graphql", ".gql", ".ts"]
        }
      ]
    },
    {
      "id": "GRAPHQL_NO_INPUT_TYPE",
      "name": "Multiple arguments instead of Input type",
      "category": "graphql",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Multiple arguments without Input type",
        "Hard to maintain",
        "No reusability"
      ],
      "fix": [
        "Create Input types",
        "Group related arguments",
        "Improve schema"
      ],
      "recommendation": {
        "title": "Use Input types for complex arguments",
        "description": "Use GraphQL Input types for mutations with multiple arguments.",
        "library": "GraphQL"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "argument.*\\w+:\\s*\\[|arg.*\\[\\w+\\]",
          "message": "Consider Input type for list arguments",
          "fileExtensions": [".graphql", ".gql", ".ts"]
        }
      ]
    }
  ]
}
