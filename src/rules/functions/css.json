{
  "version": "1.0",
  "functions": [
    {
      "id": "CSS_INLINE_STYLES",
      "name": "Inline styles detected",
      "description": "Inline styles prevent CSS optimization and reduce maintainability.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "react",
        "vue",
        "svelte",
        "angular"
      ],
      "category": "css",
      "recommendation": {
        "title": "Use CSS classes instead of inline styles",
        "description": "Inline styles prevent CSS optimization and reduce maintainability.",
        "library": "CSS Modules, styled-components"
      },
      "catches": [
        "Inline styles in components",
        "No CSS optimization",
        "Hard to maintain"
      ],
      "fix": [
        "Use CSS classes",
        "Use CSS Modules",
        "Use styled-components"
      ],
      "condition": {
        "type": "regex",
        "pattern": "style=\\{",
        "fileExtensions": [
          ".tsx",
          ".jsx",
          ".vue",
          ".svelte"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Inline style detected - use CSS classes"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_GLOBAL_NAMESPACE",
      "name": "Global CSS without scoping",
      "description": "Use CSS modules, CSS-in-JS, or scoped styles to prevent global namespace pollution.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "react",
        "vue",
        "svelte",
        "angular"
      ],
      "category": "css",
      "recommendation": {
        "title": "Scope CSS to components",
        "description": "Use CSS modules, CSS-in-JS, or scoped styles to prevent global namespace pollution.",
        "library": "CSS Modules, Vue scoped CSS"
      },
      "catches": [
        "Global CSS without scoping",
        "Namespace pollution",
        "Style conflicts"
      ],
      "fix": [
        "Use CSS Modules",
        "Use scoped styles",
        "Use CSS-in-JS"
      ],
      "condition": {
        "type": "regex",
        "pattern": "^\\.[a-z][a-z0-9]*\\s*\\{",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Global CSS class found - consider scoping"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_IMPORTANT_ABUSE",
      "name": "Overuse of !important",
      "description": "!important breaks CSS specificity and makes maintenance difficult.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Avoid !important declarations",
        "description": "!important breaks CSS specificity and makes maintenance difficult.",
        "library": "CSS"
      },
      "catches": [
        "!important used excessively",
        "Breaks CSS specificity",
        "Hard to maintain"
      ],
      "fix": [
        "Use proper specificity",
        "Avoid !important",
        "Use more specific selectors"
      ],
      "condition": {
        "type": "regex",
        "pattern": "!important",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less",
          ".tsx",
          ".jsx",
          ".vue",
          ".svelte"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "!important found - refactor to use proper specificity"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_SPECIFICITY_HIGH",
      "name": "High CSS specificity",
      "description": "High specificity selectors are hard to override and maintain.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Keep specificity low",
        "description": "High specificity selectors are hard to override and maintain.",
        "library": "BEM, CSS Modules"
      },
      "catches": [
        "High specificity selectors",
        "Hard to override",
        "Maintenance issues"
      ],
      "fix": [
        "Use BEM methodology",
        "Keep selectors simple",
        "Use CSS Modules"
      ],
      "condition": {
        "type": "regex",
        "pattern": "#[a-z]+\\s+[a-z]+\\s+[a-z]+\\s*\\{|#[a-z]+#[a-z]+|!important",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "High specificity selector - simplify"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_MAGIC_NUMBERS",
      "name": "Magic numbers in CSS",
      "description": "Hardcoded pixel values make responsive design harder. Use CSS variables.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Use CSS custom properties",
        "description": "Hardcoded pixel values make responsive design harder. Use CSS variables.",
        "library": "CSS Custom Properties"
      },
      "catches": [
        "Hardcoded pixel values",
        "Magic numbers in CSS",
        "Hard to maintain"
      ],
      "fix": [
        "Use CSS custom properties",
        "Define spacing variables",
        "Use rem/em units"
      ],
      "condition": {
        "type": "regex",
        "pattern": "(width|height|margin|padding|top|left|right|bottom):\\s*\\d+px",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Magic number in CSS - use variables"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_HARDCODED_COLORS",
      "name": "Hardcoded color values",
      "description": "Hardcoded colors prevent theming. Use CSS variables.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Use CSS custom properties for colors",
        "description": "Hardcoded colors prevent theming. Use CSS variables.",
        "library": "CSS Custom Properties"
      },
      "catches": [
        "Hardcoded color values",
        "No theming support",
        "Hard to change globally"
      ],
      "fix": [
        "Use CSS variables for colors",
        "Define color palette",
        "Enable theming"
      ],
      "condition": {
        "type": "regex",
        "pattern": "(color|background|border):\\s*#[0-9a-fA-F]{3,6}",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Hardcoded color - use CSS variable"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_FLEX_GAP",
      "name": "Using margins instead of gap",
      "description": "The gap property is cleaner than margin hacks for flex/grid containers.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Use gap for flex/grid spacing",
        "description": "The gap property is cleaner than margin hacks for flex/grid containers.",
        "library": "CSS Flexbox, CSS Grid"
      },
      "catches": [
        "Using margins instead of gap",
        "Extra markup needed",
        "Inconsistent spacing"
      ],
      "fix": [
        "Use gap property",
        "Remove margin hacks",
        "Simplify layout"
      ],
      "condition": {
        "type": "regex",
        "pattern": "display:\\s*flexmargin-(right|bottom)",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Consider using gap instead of margins"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_FONT_FAMILY",
      "name": "Web fonts without font-display",
      "description": "font-display prevents invisible text while fonts load.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Add font-display for web fonts",
        "description": "font-display prevents invisible text while fonts load.",
        "library": "CSS"
      },
      "catches": [
        "Web font without font-display",
        "Invisible text on load",
        "Poor UX"
      ],
      "fix": [
        "Add font-display: swap",
        "Use optional for faster loading",
        "Prevent FOIT"
      ],
      "condition": {
        "type": "regex",
        "pattern": "@font-face\\}",
        "fileExtensions": [
          ".css",
          ".scss",
          ".less"
        ]
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Web font without font-display - add swap or optional"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "CSS_DUPLICATE_VALUES",
      "name": "Duplicate CSS values across files",
      "description": "Colors, font sizes, and spacing values used multiple times should be defined as CSS variables for consistency and easier maintenance.",
      "enabled": true,
      "priority": 1,
      "frameworks": [],
      "category": "css",
      "recommendation": {
        "title": "Use CSS custom properties for repeated values",
        "description": "Colors, font sizes, and spacing values used multiple times should be defined as CSS variables for consistency and easier maintenance.",
        "library": "CSS Custom Properties"
      },
      "catches": [
        "Duplicate CSS values",
        "Inconsistent styling",
        "Hard to maintain"
      ],
      "fix": [
        "Use CSS custom properties",
        "Define design tokens",
        "Centralize values"
      ],
      "condition": {
        "type": "exists",
        "field": "content"
      },
      "action": {
        "type": "flag",
        "severity": "low",
        "message": "Check for findDuplicateCssValues",
        "helper": "findDuplicateCssValues",
        "params": {
          "message": "Duplicate CSS value",
          "threshold": 2,
          "skipPaths": [
            "node_modules",
            "dist",
            ".attune",
            "research"
          ]
        }
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    }
  ]
}