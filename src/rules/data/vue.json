{
  "rules": [
    {
      "id": "VUE_PROP_DEFAULT_MUTATION",
      "name": "Mutating prop in component",
      "category": "architecture",
      "severity": "critical",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Modifying props directly",
        "Parent component state corruption",
        "Vue warnings in console"
      ],
      "fix": [
        "Create local copy with ref/reactive",
        "Emit events to parent for changes",
        "Use v-model with props"
      ],
      "recommendation": {
        "title": "Do not mutate props",
        "description": "Props should be treated as read-only. Use a local copy if you need to modify it.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "props\\.",
          "message": "Props access detected"
        }
      ]
    },
    {
      "id": "VUE_V_FOR_INDEX",
      "name": "v-for without key",
      "category": "architecture",
      "severity": "high",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Missing key on list items",
        "Incorrect DOM updates",
        "Performance issues"
      ],
      "fix": [
        "Add :key with unique ID",
        "Avoid using index as key",
        "Use stable identifiers"
      ],
      "recommendation": {
        "title": "Add key to v-for",
        "description": "v-for should always have a unique key for proper list rendering.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "v-for",
          "message": "v-for directive detected"
        }
      ]
    },
    {
      "id": "VUE_WATCH_IMMEDIATE",
      "name": "watch without immediate option",
      "category": "architecture",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Watch doesn't run on initial value",
        "Missing initial setup logic",
        "Confusing behavior"
      ],
      "fix": [
        "Add immediate: true to watch",
        "Consider using watchEffect for simpler cases",
        "Handle both initial and change cases"
      ],
      "recommendation": {
        "title": "Use immediate option for watch on mount",
        "description": "If you need the initial value in watch, use immediate: true.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "watch\\s*\\(",
          "message": "watch function detected"
        }
      ]
    },
    {
      "id": "VUE_REACTIVITY_LEAK",
      "name": "Unreactive object mutation",
      "category": "architecture",
      "severity": "high",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Changes not detected by Vue",
        "UI doesn't update",
        "Hard-to-debug issues"
      ],
      "fix": [
        "Use ref() for reactive primitives",
        "Use reactive() for objects properly",
        "Assign new values, don't mutate"
      ],
      "recommendation": {
        "title": "Fix unreactive object mutation",
        "description": "Mutating objects directly breaks Vue reactivity. Use reactive() properly.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "reactive|ref|watch|computed",
          "message": "Reactivity API found",
          "fileExtensions": [".vue", ".ts", ".js"]
        }
      ]
    },
    {
      "id": "VUE_COMPOSABLE_SIDE_EFFECT",
      "name": "Composable with side effects",
      "category": "architecture",
      "severity": "medium",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Hidden dependencies in composables",
        "Hard to test composables",
        "Unexpected behavior"
      ],
      "fix": [
        "Document side effects clearly",
        "Return cleanup functions",
        "Consider pure composables first"
      ],
      "recommendation": {
        "title": "Avoid side effects in composables",
        "description": "Composables with side effects should be explicit about them.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "use[A-Z]\\w+\\(|export\\s+function\\s+use",
          "message": "Composable function found",
          "fileExtensions": [".vue", ".ts", ".js"]
        }
      ]
    },
    {
      "id": "VUE_SCOPE_CSS",
      "name": "Deep selectors in scoped CSS",
      "category": "performance",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Styles leaking to other components",
        "Hard to maintain styles",
        "Scoped CSS bypassed"
      ],
      "fix": [
        "Use scoped CSS without deep selectors",
        "Pass classes to child components",
        "Refactor component structure"
      ],
      "recommendation": {
        "title": "Avoid deep selectors in scoped CSS",
        "description": "Deep selectors in scoped CSS can cause maintenance issues.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": ">>>",
          "message": "Deep selector in scoped CSS"
        }
      ]
    },
    {
      "id": "VUE_ASYNC_COMPONENT",
      "name": "Async component without loading",
      "category": "performance",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Blank space while loading",
        "Poor user experience",
        "Layout shift"
      ],
      "fix": [
        "Add loading component with defineAsyncComponent",
        "Use Suspense with async components",
        "Add delay option"
      ],
      "recommendation": {
        "title": "Add loading component for async components",
        "description": "Async components should have a loading component.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "loading|lazy|Suspense",
          "message": "Async handling found"
        }
      ]
    },
    {
      "id": "VUE_EMIT_WITHOUT_DECLARE",
      "name": "Emits without declaration",
      "category": "typescript",
      "severity": "medium",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "No type safety for emits",
        "Can't see emitted events",
        "Runtime errors"
      ],
      "fix": [
        "Use defineEmits with type-safe events",
        "Define emits in component options",
        "Use TypeScript for full typing"
      ],
      "recommendation": {
        "title": "Declare emits in component",
        "description": "Emits should be declared in the component for type safety.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "defineEmits\\(|emits:\\s*\\[",
          "message": "Emits declaration found",
          "fileExtensions": [".vue", ".ts"]
        }
      ]
    },
    {
      "id": "VUE_REACTIVE_PRIMITIVE",
      "name": "Wrong reactivity primitive",
      "category": "architecture",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Using wrong primitive type",
        "Reactivity not working",
        "Unnecessary unwrapping"
      ],
      "fix": [
        "Use ref() for primitives (string, number, boolean)",
        "Use reactive() for objects",
        "Use shallowRef for large arrays"
      ],
      "recommendation": {
        "title": "Use correct reactivity primitive",
        "description": "Use ref() for primitives and reactive() for objects.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "ref|reactive|shallowRef",
          "message": "Reactivity primitive found"
        }
      ]
    },
    {
      "id": "VUE_PROVIDE_INJECT",
      "name": "Provide/inject without reactivity",
      "category": "architecture",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Values not updating in descendants",
        "Provide/inject not working",
        "Static values passed"
      ],
      "fix": [
        "Pass ref() or reactive() objects",
        "Use toRef/toRefs for reactivity",
        "Consider using Pinia instead"
      ],
      "recommendation": {
        "title": "Use provide/inject correctly",
        "description": "Provide/inject should maintain reactivity.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "provide\\(|inject\\(|provide:\\s*\\[|inject:\\s*\\[",
          "message": "Provide/inject found",
          "fileExtensions": [".vue", ".ts"]
        }
      ]
    },
    {
      "id": "VUE_STORE_ACTION_TYPE",
      "name": "String-based store actions",
      "category": "typescript",
      "severity": "low",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "No type safety for actions",
        "Hard to refactor",
        "Magic strings"
      ],
      "fix": [
        "Use Pinia with TypeScript",
        "Define action types explicitly",
        "Use composition API stores"
      ],
      "recommendation": {
        "title": "Use typed store actions",
        "description": "String-based actions reduce type safety. Use typed actions.",
        "library": "Pinia"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "store|pinia|action|dispatch",
          "message": "Store found"
        }
      ]
    },
    {
      "id": "VUE_MIXINS_DEPRECATED",
      "name": "Using deprecated mixins",
      "category": "architecture",
      "severity": "medium",
      "frameworks": ["vue", "nuxt"],
      "catches": [
        "Using deprecated Vue feature",
        "Name collisions",
        "Hard to debug"
      ],
      "fix": [
        "Extract logic to composables",
        "Use composables instead of mixins",
        "Refactor to composition API"
      ],
      "recommendation": {
        "title": "Avoid using mixins",
        "description": "Mixins are deprecated. Use composables instead.",
        "library": "Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "mixins\\s*:",
          "message": "Mixins usage detected - consider composables instead"
        }
      ]
    }
  ]
}
