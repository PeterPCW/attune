# Attune Ignore Patterns
# Add patterns to exclude from analysis
# One pattern per line, supports:
# - Exact paths: src/oldcode/
# - Glob patterns: **/*.test.ts
# - File extensions: *.log
# - Rule-specific ignores: RULE_ID:path (skip only that rule on that path)

node_modules/
dist/
build/
.git/
.env
*.lock

# Exclude attune's own rule definitions (these trigger false positives)
# The rules in src/rules/ contain patterns that match themselves
src/rules/

# Exclude test files by default
# They contain test patterns that match rule patterns
# Remove this if you want to scan test files
**/__tests__/
*.test.ts
*.spec.ts
test/
coverage/

# Exclude utility files that contain detection patterns (not actual issues)
# These files contain regex patterns FOR detecting issues, not the issues themselves
src/core/sanitizer.ts
src/utils/retry.ts
src/core/detector/index.ts

# Rule-specific ignores - skip only specific rules, run all others on these files
# Format: RULE_ID:path (glob patterns supported)
# OWASP_A08_INTEGRITY_FAIL matches 'uploads' string in type definitions
OWASP_A08_INTEGRITY_FAIL:src/types/index.ts