      ]
    },
    {
      "id": "TS_TYPE_NARROWING",
      "name": "Insufficient type narrowing",
      "category": "typescript",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "No type narrowing",
        "Type not narrowed",
        "Potential errors"
      ],
      "fix": [
        "Use type guards",
        "Add instanceof checks",
        "Use typeof"
      ],
      "recommendation": {
        "title": "Use proper type narrowing",
        "description": "Use type guards and narrowing to ensure type safety.",
        "library": "TypeScript"
      },
      "fileExtensions": [".ts", ".tsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "if\\s*\\([^)]*\\s*instanceof\\s+",
          "message": "instanceof check found - good for type narrowing"
        }
      ]
    },
    {
      "id": "TS_DISCRIMINATED_UNIONS",
