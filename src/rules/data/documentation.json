{
  "rules": [
    {
      "id": "DOC_API_MISSING",
      "name": "Missing API documentation",
      "category": "documentation",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No API documentation",
        "Hard for consumers to use API",
        "Integration difficulties"
      ],
      "fix": [
        "Add OpenAPI/Swagger annotations",
        "Generate docs from code",
        "Create interactive API explorer"
      ],
      "recommendation": {
        "title": "Add API documentation",
        "description": "API endpoints should be documented with OpenAPI/Swagger.",
        "library": "Swagger, OpenAPI"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "swagger|openapi|@schema|@response",
          "message": "API documentation found"
        }
      ]
    },
    {
      "id": "DOC_NO_README",
      "name": "Missing README",
      "category": "documentation",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "No README file",
        "No project documentation",
        "Hard for others to understand project"
      ],
      "fix": [
        "Create README.md with project overview",
        "Include installation instructions",
        "Add usage examples"
      ],
      "recommendation": {
        "title": "Add README",
        "description": "Every project should have a README explaining what it is and how to use it.",
        "library": "Documentation"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "README|readme",
          "message": "README found"
        }
      ]
    },
    {
      "id": "DOC_NO_ENV_EXAMPLE",
      "name": "Missing environment example file",
      "category": "documentation",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "No .env.example file",
        "No documentation of required env vars",
        "Hard for contributors to know what vars needed"
      ],
      "fix": [
        "Create .env.example with placeholder values",
        "Document all required environment variables",
        "Exclude sensitive values"
      ],
      "recommendation": {
        "title": "Add .env.example",
        "description": "Projects using environment variables should have a .env.example file documenting required vars.",
        "library": "dotenv"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "\\.env\\.example|env\\.example",
          "message": "Env example found"
        }
      ]
    },
    {
      "id": "DOC_NO_CONTRIBUTING",
      "name": "Missing CONTRIBUTING guide",
      "category": "documentation",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "No CONTRIBUTING guide",
        "No contribution guidelines",
        "Hard for contributors to know how to help"
      ],
      "fix": [
        "Create CONTRIBUTING.md",
        "Document how to set up dev environment",
        "Explain how to submit changes"
      ],
      "recommendation": {
        "title": "Add CONTRIBUTING guide",
        "description": "Open source projects should have a CONTRIBUTING guide.",
        "library": "Documentation"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "CONTRIBUTING|contributing",
          "message": "Contributing guide found"
        }
      ]
    },
    {
      "id": "DOC_ENV_NOT_DOCUMENTED",
      "name": "Environment variables not documented",
      "category": "documentation",
      "severity": "info",
      "frameworks": [],
      "catches": [
        "Code uses env vars not in .env.example",
        "Undocumented configuration",
        "Hard for team to know all required vars"
      ],
      "fix": [
        "Add used env vars to .env.example",
        "Document all configuration options",
        "Keep .env.example in sync with code"
      ],
      "recommendation": {
        "title": "Document environment variables",
        "description": "All environment variables used in code should be documented in .env.example.",
        "library": "dotenv"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "process\\.env\\.[A-Z_]+",
          "message": "Environment variable reference found"
        }
      ]
    }
  ]
}
