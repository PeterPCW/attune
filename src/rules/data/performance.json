        "library": "React, Vue"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "useMemo|useCallback|computed|memo",
          "message": "Memoization found"
        }
      ]
    },
    {
      "id": "PERF_BIND_IN_RENDER",
