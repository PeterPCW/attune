    {
      "id": "PERF_EVENT_LISTENER_LEAK",
      "name": "Event listener without cleanup",
      "category": "performance",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "addEventListener without removeEventListener",
        "Memory leaks from event listeners",
        "Detached DOM elements with listeners"
      ],
      "fix": [
        "Add removeEventListener in cleanup",
        "Use AbortController for addEventListener",
        "Remove listeners on component unmount (React)"
      ],
      "recommendation": {
        "title": "Clean up event listeners",
        "description": "Event listeners should be removed when no longer needed to prevent memory leaks.",
        "library": "Event handling"
      },
      "fileExtensions": [".ts", ".js", ".tsx", ".jsx"],
      "helpers": [
        {
          "name": "findEventListenerWithoutCleanup",
          "params": {
            "message": "Event listener may cause memory leak - no cleanup found"
          }
        }
      ]
    }
