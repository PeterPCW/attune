      "priority": 1,
      "frameworks": [
        "aiohttp"
      ],
      "languages": [
        "python"
      ],
      "category": "performance",
      "recommendation": {
        "title": "Enable compression",
        "description": "Use aiohttp-compress or configure middleware.",
        "library": "aiohttp"
      },
      "condition": {
        "type": "regex",
        "pattern": "web\\.Application\\(\\)"
      },
      "action": {
        "type": "flag",
