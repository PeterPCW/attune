{
  "rules": [
    {
      "id": "TEST_COVERAGE_CONFIG",
      "name": "Missing test coverage configuration",
      "category": "testing",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No visibility into code coverage",
        "Can't track tested code",
        "Unknown test quality"
      ],
      "fix": [
        "Add coverage config to test runner",
        "Run coverage with tests",
        "Generate coverage reports"
      ],
      "recommendation": {
        "title": "Add test coverage configuration",
        "description": "Configure test coverage to track code quality. Add coverage configuration to your test runner.",
        "library": "vitest, jest"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "vitest\\.config\\.\" ?ts|jest\\.config\\.\" ?ts|coverage.*provider",
          "message": "Test coverage configuration found",
          "fileExtensions": [".ts", ".js"],
          "excludePatterns": ["package\\.json"]
        },
        {
          "type": "regex",
          "pattern": "\"coverage\"",
          "message": "Coverage configuration found",
          "fileExtensions": [".json"],
          "excludePatterns": ["node_modules"]
        }
      ]
    },
    {
      "id": "TEST_COVERAGE_THRESHOLDS",
      "name": "Missing coverage thresholds",
      "category": "testing",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "No enforcement of coverage",
        "Low coverage accepted",
        "Code quality issues"
      ],
      "fix": [
        "Set coverage thresholds in config",
        "Fail CI below threshold",
        "Aim for 80%+ coverage"
      ],
      "recommendation": {
        "title": "Set minimum coverage thresholds",
        "description": "Add coverage thresholds to enforce minimum code coverage standards in CI.",
        "library": "vitest, jest"
      },
      "fileExtensions": [".json", ".ts", ".js"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "coverageThreshold",
          "message": "Coverage threshold configuration found"
        }
      ]
    },
    {
      "id": "TEST_COVERAGE_LOW",
      "name": "Test coverage below threshold",
      "category": "testing",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Code not tested",
        "Potential bugs undetected",
        "Low confidence in code"
      ],
      "fix": [
        "Write more tests",
        "Aim for 80%+ coverage",
        "Prioritize critical paths"
      ],
      "recommendation": {
        "title": "Improve test coverage",
        "description": "Test coverage is below recommended threshold. Aim for 80%+ coverage.",
        "library": "vitest, jest"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "it\\.only|test\\.only|describe\\.only",
          "message": "Test with .only found - may indicate incomplete testing"
        }
      ],
      "metadata": {
        "requiresCoverageJson": true
      }
    },
    {
      "id": "TEST_FILES_MISSING",
      "name": "Files without corresponding tests",
      "category": "testing",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No tests for source files",
        "Untested functionality",
        "Risk of regressions"
      ],
      "fix": [
        "Create test files for source",
        "Name tests matching source",
        "Cover critical paths"
      ],
      "recommendation": {
        "title": "Add test files",
        "description": "Source files should have corresponding test files.",
        "library": "Testing"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "describe\\(|it\\(|test\\(",
          "message": "Test file found",
          "fileExtensions": [".test.ts", ".spec.ts", ".test.js", ".spec.js"]
        }
      ]
    },
    {
      "id": "TEST_NO_E2E",
      "name": "No E2E tests for UI project",
      "category": "testing",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No E2E tests for UI",
        "No browser testing",
        "User flows not tested"
      ],
      "fix": [
        "Add Playwright or Cypress",
        "Write E2E tests for key user flows",
        "Test critical paths in real browser"
      ],
      "recommendation": {
        "title": "Add E2E tests",
        "description": "Projects with UI components should have E2E tests to verify user flows work correctly.",
        "library": "Playwright, Cypress"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "playwright|cypress|e2e|@playwright|chromium\\.launch",
          "message": "E2E test setup found"
        }
      ]
    }
  ]
}
