        "title": "Add response_model",
        "description": "Use response_model parameter for type validation.",
        "library": "Starlette"
      },
      "condition": {
        "type": "regex",
        "pattern": "async\\s+def\\s+\\w+\\(\\)\\s*->"
      },
      "action": {
        "type": "flag",
        "severity": "medium",
        "message": "Consider adding response_model"
      },
      "projectTypes": [
        "webapp",
        "saas"
      ]
    },
    {
      "id": "STARLETTE_DEBUG_TRUE",
      "name": "Debug mode in production",
      "description": "Set debug=False in production settings.",
      "enabled": true,
      "priority": 1,
      "frameworks": [
        "starlette"
      ],
      "languages": [
        "python"
      ],
      "category": "security",
