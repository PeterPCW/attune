{
  "rules": [
    {
      "id": "WS_NO_HEARTBEAT",
      "name": "WebSocket missing heartbeat",
      "category": "websockets",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Dead connections not detected",
        "Stale connections using resources",
        "Ghost clients"
      ],
      "fix": [
        "Implement ping/pong heartbeat",
        "Set heartbeat interval",
        "Handle disconnection"
      ],
      "recommendation": {
        "title": "Implement heartbeat/ping-pong",
        "description": "Heartbeats detect disconnected clients and prevent stale connections.",
        "library": "ws, socket.io"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "heartbeat|ping|pong|keepAlive",
          "message": "Heartbeat found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "WS_NO_RECONNECT",
      "name": "Client missing reconnection logic",
      "category": "websockets",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "App stops working on disconnect",
        "Manual refresh required",
        "Poor user experience"
      ],
      "fix": [
        "Enable auto-reconnect",
        "Handle reconnection events",
        "Update UI on reconnect"
      ],
      "recommendation": {
        "title": "Add reconnection handling",
        "description": "Auto-reconnect when connection is lost.",
        "library": "socket.io-client, ws"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "reconnect|autoReconnect|reconnection",
          "message": "Reconnection found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "WS_NO_AUTH",
      "name": "WebSocket without authentication",
      "category": "websockets",
      "severity": "critical",
      "frameworks": [],
      "catches": [
        "Unauthenticated connections",
        "Security vulnerabilities",
        "Anyone can connect"
      ],
      "fix": [
        "Pass token on handshake",
        "Validate on connection",
        "Use middleware"
      ],
      "recommendation": {
        "title": "Authenticate WebSocket connections",
        "description": "WebSocket connections should be authenticated on handshake.",
        "library": "socket.io, ws"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "ws\\.|socket\\.|WebSocket\\(",
          "message": "WebSocket found - add auth",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "WS_NO_MESSAGE_TYPES",
      "name": "Using string messages instead of typed objects",
      "category": "websockets",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "String messages hard to debug",
        "No validation",
        "Type errors at runtime"
      ],
      "fix": [
        "Use JSON with type field",
        "Define message schemas",
        "Validate on receive"
      ],
      "recommendation": {
        "title": "Use typed message format",
        "description": "Use JSON with type field for better debugging and validation.",
        "library": "socket.io, ws"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "emit\\s*\\([^,]+,|on\\s*\\([^,]+,",
          "message": "Socket event found - consider typed messages",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "WS_ROOM_BROADCAST",
      "name": "Broadcasting to all instead of rooms",
      "category": "websockets",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Messages sent to everyone",
        "Data leaked to wrong users",
        "Wasted bandwidth"
      ],
      "fix": [
        "Use socket.io rooms",
        "Join user to room by ID",
        "Broadcast to specific room"
      ],
      "recommendation": {
        "title": "Use rooms for targeted broadcasts",
        "description": "Broadcast to specific rooms rather than all connected clients.",
        "library": "socket.io rooms"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "io\\.emit\\(|broadcast\\(|to\\(",
          "message": "Broadcast found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "WS_NO_RATE_LIMIT",
      "name": "WebSocket missing rate limiting",
      "category": "websockets",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Client can flood with messages",
        "DoS vulnerability",
        "Server overload"
      ],
      "fix": [
        "Add rate limiter middleware",
        "Limit messages per second",
        "Throttle per connection"
      ],
      "recommendation": {
        "title": "Rate limit messages",
        "description": "Limit message frequency per client to prevent abuse.",
        "library": "socket.io rate limiter"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "throttle|rateLimit|throttle",
          "message": "Rate limiting found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    }
  ]
}
