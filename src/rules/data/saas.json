{
  "rules": [
    {
      "id": "SAAS_NO_PAGINATION",
      "name": "Missing pagination on list endpoints",
      "category": "performance",
      "severity": "high",
      "frameworks": ["express", "fastify", "nextjs"],
      "catches": [
        "API endpoints returning all records without limits",
        "No page/limit parameters on list routes",
        "Unbounded result sets"
      ],
      "fix": [
        "Add page and limit query parameters",
        "Implement offset/limit or cursor-based pagination",
        "Set reasonable default limits"
      ],
      "recommendation": {
        "title": "Add pagination to list endpoints",
        "description": "Without pagination, list endpoints can return unbounded results causing memory issues and slow responses.",
        "library": "API Design"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "app\\.(get|post|put|patch)\\s*\\(['\"`](?!.*/(page|limit|offset|pagination))",
          "message": "Route handler may return unpaginated results - add pagination parameters"
        }
      ]
    },
    {
      "id": "SAAS_N_PLUS_1",
      "name": "Potential N+1 query problem",
      "category": "performance",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "Loop fetching related data for each item",
        "Multiple database calls in forEach/map",
        "Missing eager loading"
      ],
      "fix": [
        "Use ORM's include/with for eager loading",
        "Use JOINs instead of loops",
        "Batch fetch related records"
      ],
      "recommendation": {
        "title": "Use eager loading",
        "description": "N+1 queries occur when fetching records then looping to get related data. Use JOINs or eager loading.",
        "library": "ORM, Database"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "for\\s*\\(\\s*const\\s+\\w+\\s+of\\s+\\w+\\s*\\)\\s*\\{[^}]*\\.find|forEach.*\\.find",
          "message": "Potential N+1 query - loop followed by database find"
        }
      ]
    },
    {
      "id": "SAAS_NO_CACHE",
      "name": "No caching detected",
      "category": "performance",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Repeated queries for same data",
        "No caching layer configured",
        "Database hit on every request"
      ],
      "fix": [
        "Add Redis caching",
        "Cache frequently accessed data",
        "Set appropriate TTL"
      ],
      "recommendation": {
        "title": "Add caching layer",
        "description": "Frequently accessed data should be cached to reduce database load.",
        "library": "Redis, memory-cache"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "cache|redis|memcached",
          "message": "Caching implementation found"
        }
      ]
    },
    {
      "id": "SAAS_SYNC_BLOCKING",
      "name": "Synchronous blocking operations",
      "category": "performance",
      "severity": "high",
      "frameworks": ["nodejs"],
      "catches": [
        "readFileSync, writeFileSync usage",
        "Blocking the event loop",
        "Synchronous fs operations"
      ],
      "fix": [
        "Use async/await versions",
        "Use fs.promises",
        "Move to worker threads if needed"
      ],
      "recommendation": {
        "title": "Use async operations",
        "description": "Synchronous operations block the event loop. Use async/await for I/O operations.",
        "library": "Node.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "readFileSync|writeFileSync|existsSync|readdirSync",
          "message": "Synchronous file operation detected - use async version"
        }
      ]
    },
    {
      "id": "SAAS_NO_RATE_LIMIT",
      "name": "No rate limiting detected",
      "category": "security",
      "severity": "high",
      "frameworks": ["express", "fastify"],
      "catches": [
        "No rate limiting on endpoints",
        "Vulnerable to brute force",
        "No protection against DDoS"
      ],
      "fix": [
        "Add express-rate-limit",
        "Configure limits per endpoint",
        "Add stricter limits for auth endpoints"
      ],
      "recommendation": {
        "title": "Add rate limiting",
        "description": "APIs without rate limiting are vulnerable to abuse and DDoS attacks.",
        "library": "express-rate-limit"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "rateLimit|rate.?limit",
          "message": "Rate limiting found"
        }
      ]
    },
    {
      "id": "SAAS_NO_AUTH",
      "name": "Route without authentication",
      "category": "security",
      "severity": "critical",
      "frameworks": ["express", "fastify"],
      "catches": [
        "API endpoints without auth check",
        "Routes that should be protected",
        "Missing auth middleware"
      ],
      "fix": [
        "Add authentication middleware",
        "Protect sensitive endpoints",
        "Use auth middleware on routes"
      ],
      "recommendation": {
        "title": "Add authentication",
        "description": "API endpoints should require authentication unless explicitly public.",
        "library": "Auth, JWT, Sessions"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "app\\.(get|post|put|patch|delete)\\s*\\(\\s*['\"`]/(?!auth|login|register|public)",
          "message": "Route may lack authentication middleware"
        }
      ]
    },
    {
      "id": "SAAS_NO_AUTHZ",
      "name": "Potential missing authorization checks",
      "category": "security",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "User can access others' data",
        "No ownership verification",
        "Missing permission checks"
      ],
      "fix": [
        "Add ownership checks",
        "Verify user owns resource",
        "Add role-based checks"
      ],
      "recommendation": {
        "title": "Add authorization checks",
        "description": "After authentication, verify user has permission to access the resource.",
        "library": "Authorization"
      },
      "fileExtensions": [".ts", ".js", ".tsx", ".jsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "(checkPermission|hasPermission|canAccess|isAuthorized|verifyOwnership|validateAccess)\\s*\\(",
          "message": "Authorization check found"
        }
      ]
    },
    {
      "id": "SAAS_NO_TENANT_ISOLATION",
      "name": "Potential missing tenant isolation",
      "category": "security",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No tenant ID filtering",
        "Users can see other tenants' data",
        "Missing RLS policies"
      ],
      "fix": [
        "Add tenant_id to all queries",
        "Implement RLS policies",
        "Verify tenant context"
      ],
      "recommendation": {
        "title": "Add tenant isolation",
        "description": "Multi-tenant apps must filter by tenant ID to prevent data leaks between tenants.",
        "library": "Database, Row-Level Security"
      },
      "fileExtensions": [".ts", ".js", ".tsx", ".jsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "(getTenantId|getOrganizationId|filterByTenant|verifyTenant|ensureTenantAccess)\\s*\\(",
          "message": "Tenant filtering found"
        }
      ]
    },
    {
      "id": "SAAS_NO_GRACEFUL_SHUTDOWN",
      "name": "No graceful shutdown handling",
      "category": "reliability",
      "severity": "medium",
      "frameworks": ["nodejs"],
      "catches": [
        "No SIGTERM handler",
        "Connections dropped on shutdown",
        "In-flight requests lost"
      ],
      "fix": [
        "Handle SIGTERM/SIGINT",
        "Close database connections",
        "Finish in-flight requests"
      ],
      "recommendation": {
        "title": "Implement graceful shutdown",
        "description": "Handle SIGTERM/SIGINT to close connections and finish processing requests before exiting.",
        "library": "Node.js"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "process\\.(on|once)\\s*\\(\\s*['\"`]SIGTERM",
          "message": "Graceful shutdown handler found"
        }
      ]
    },
    {
      "id": "SAAS_NO_HEALTH_CHECK",
      "name": "No health check endpoint",
      "category": "reliability",
      "severity": "medium",
      "frameworks": ["express", "fastify"],
      "catches": [
        "No /health endpoint",
        "Load balancer can't check status",
        "Missing liveness probe"
      ],
      "fix": [
        "Add /health and /ready endpoints",
        "Check dependencies in health check",
        "Configure Kubernetes probes"
      ],
      "recommendation": {
        "title": "Add health check endpoint",
        "description": "Health checks (/health, /ready) are needed for load balancers and orchestration.",
        "library": "Kubernetes, Load Balancers"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "['\"`]/(health|ready|liveness|ping)['\"`]",
          "message": "Health check endpoint found"
        }
      ]
    },
    {
      "id": "SAAS_NO_API_VERSION",
      "name": "API not versioned",
      "category": "architecture",
      "severity": "medium",
      "frameworks": ["express", "fastify"],
      "catches": [
        "No API versioning",
        "Breaking changes affect all clients",
        "No way to deprecate safely"
      ],
      "fix": [
        "Add /v1/, /v2/ to routes",
        "Version in header Accept",
        "Plan deprecation strategy"
      ],
      "recommendation": {
        "title": "Version your API",
        "description": "APIs should be versioned (/v1/, /v2/) to allow breaking changes without affecting clients.",
        "library": "API Design"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "['\"`]/(v1|v2|v3)/",
          "message": "API versioning found"
        }
      ]
    },
    {
      "id": "SAAS_NO_ERROR_RESPONSE",
      "name": "No standardized error handler",
      "category": "architecture",
      "severity": "medium",
      "frameworks": ["express", "fastify"],
      "catches": [
        "Inconsistent error formats",
        "No error middleware",
        "Different error responses per route"
      ],
      "fix": [
        "Create error middleware",
        "Standardize error format",
        "Use error classes"
      ],
      "recommendation": {
        "title": "Standardize error responses",
        "description": "Errors should follow consistent format across all endpoints.",
        "library": "API Design"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "errorMiddleware|errorHandler|ErrorResponse",
          "message": "Error handler found"
        }
      ]
    },
    {
      "id": "SAAS_NO_REQUEST_ID",
      "name": "No request ID tracking",
      "category": "reliability",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "No request tracing",
        "Hard to debug across services",
        "Missing correlation IDs"
      ],
      "fix": [
        "Add X-Request-ID header",
        "Pass request ID to logs",
        "Use OpenTelemetry"
      ],
      "recommendation": {
        "title": "Add request ID tracking",
        "description": "Add X-Request-ID headers for request tracing across services.",
        "library": "Logging, Tracing"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "requestId|request-id|traceId|correlationId",
          "message": "Request tracking found"
        }
      ]
    },
    {
      "id": "SAAS_NO_CORS_CONFIG",
      "name": "Missing or overly permissive CORS",
      "category": "security",
      "severity": "high",
      "frameworks": ["express", "fastify"],
      "catches": [
        "CORS not configured",
        "Using wildcard origin",
        "Too permissive"
      ],
      "fix": [
        "Configure allowed origins",
        "Use environment-based config",
        "Never use * in production"
      ],
      "recommendation": {
        "title": "Configure CORS properly",
        "description": "CORS should whitelist specific origins, not use wildcard * in production.",
        "library": "CORS"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "cors\\s*\\(",
          "message": "CORS configured"
        }
      ]
    },
    {
      "id": "SAAS_SESSION_FIXATION",
      "name": "Session fixation vulnerability",
      "category": "security",
      "severity": "high",
      "frameworks": ["express"],
      "catches": [
        "Session not regenerated on login",
        "Session fixation possible",
        "Same ID before and after auth"
      ],
      "fix": [
        "Call req.session.regenerate() on login",
        "Create new session after auth",
        "Use secure session config"
      ],
      "recommendation": {
        "title": "Regenerate session on login",
        "description": "Session IDs should be regenerated after authentication to prevent fixation attacks.",
        "library": "Sessions"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "session\\.regenerate|req\\.session\\.regenerate",
          "message": "Session regeneration found"
        }
      ]
    },
    {
      "id": "SAAS_NO_INPUT_SANITIZATION",
      "name": "Missing input sanitization",
      "category": "security",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No input validation",
        "Raw user input used",
        "Vulnerable to injection"
      ],
      "fix": [
        "Use Zod or Yup schemas",
        "Validate all inputs",
        "Sanitize before use"
      ],
      "recommendation": {
        "title": "Sanitize all inputs",
        "description": "All user input should be validated and sanitized before use.",
        "library": "Validation, Sanitization"
      },
      "fileExtensions": [".ts", ".js", ".tsx", ".jsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "(validateSchema|sanitizeInput|validateInput|parseAndValidate|request\\.validate)\\s*\\(",
          "message": "Input validation found"
        }
      ]
    },
    {
      "id": "SAAS_NO_CSRF",
      "name": "Missing CSRF protection",
      "category": "security",
      "severity": "high",
      "frameworks": ["express"],
      "catches": [
        "No CSRF tokens",
        "Vulnerable to cross-site requests",
        "State-changing ops unprotected"
      ],
      "fix": [
        "Use csurf or node-csurf middleware",
        "Add CSRF token to forms",
        "Use SameSite cookies"
      ],
      "recommendation": {
        "title": "Add CSRF protection",
        "description": "State-changing requests need CSRF tokens for browser clients.",
        "library": "CSRF"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "csurf|csrf|xsrf|anti-csrf",
          "message": "CSRF protection found"
        }
      ]
    },
    {
      "id": "SAAS_NO_HTTPS",
      "name": "Missing HTTPS enforcement",
      "category": "security",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No HTTPS redirect",
        "Traffic can be intercepted",
        "No HSTS header"
      ],
      "fix": [
        "Redirect HTTP to HTTPS",
        "Add HSTS header",
        "Use Helmet"
      ],
      "recommendation": {
        "title": "Enforce HTTPS",
        "description": "Redirect HTTP to HTTPS and set HSTS header.",
        "library": "TLS, Helmet"
      },
      "fileExtensions": [".ts", ".js", ".tsx", ".jsx"],
      "patterns": [
        {
          "type": "regex",
          "pattern": "(helmet\\(|contentSecurityPolicy|hsts|forceHTTPS|requireHTTPS)",
          "message": "HTTPS/Helmet configuration found"
        }
      ]
    },
    {
      "id": "SAAS_NO_CONNECTION_POOL",
      "name": "No database connection pooling",
      "category": "performance",
      "severity": "high",
      "frameworks": [],
      "catches": [
        "New connection per request",
        "Connection overhead",
        "Database latency"
      ],
      "fix": [
        "Use connection pool",
        "Configure pool size",
        "Reuse connections"
      ],
      "recommendation": {
        "title": "Use connection pooling",
        "description": "Without connection pooling, each request creates a new connection causing latency.",
        "library": "Database, Pg, MySQL"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "pool|Pool",
          "message": "Connection pooling found"
        }
      ]
    },
    {
      "id": "SAAS_NO_IDEMPOTENCY",
      "name": "No idempotency for mutations",
      "category": "reliability",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "No idempotency keys",
        "Retries cause duplicate actions",
        "Payments could be duplicated"
      ],
      "fix": [
        "Add idempotency key to POST",
        "Check key before processing",
        "Store key with result"
      ],
      "recommendation": {
        "title": "Add idempotency keys",
        "description": "POST/PATCH/DELETE endpoints should support idempotency to handle retry safely.",
        "library": "API Design"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "idempotency|Idempotency",
          "message": "Idempotency handling found"
        }
      ]
    }
  ]
}
