{
  "rules": [
    {
      "id": "QUEUE_NO_TIMEOUT",
      "name": "Job missing timeout",
      "category": "queues",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Jobs running forever",
        "Process hangs",
        "No failure detection"
      ],
      "fix": [
        "Add timeout to job options",
        "Set reasonable timeout values",
        "Handle timeout errors"
      ],
      "recommendation": {
        "title": "Set job timeouts",
        "description": "Jobs should have timeouts to prevent hanging processes.",
        "library": "Bull, Agenda, Redis"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "queue\\.|bull|agenda|job\\.",
          "message": "Queue job found - consider timeout",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "QUEUE_NO_RETRIES",
      "name": "Job missing retry configuration",
      "category": "queues",
      "severity": "medium",
      "frameworks": [],
      "catches": [
        "Queue jobs without retry configuration",
        "Failed jobs not retried",
        "No recovery from errors"
      ],
      "fix": [
        "Configure retry attempts",
        "Set backoff strategy",
        "Handle transient failures"
      ],
      "recommendation": {
        "title": "Configure job retries",
        "description": "Queue jobs should have explicit retry/attempts configuration. Note: This rule checks if queue-related files have retry config. Files without queue patterns are ignored.",
        "library": "Bull, Agenda"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "queue\\.|bull|agenda|BullMQ|job\\Processor",
          "message": "Queue job found - verify retry configuration",
          "fileExtensions": [".ts", ".js"],
          "excludePatterns": ["attempts|retry|backoff|retryCount"]
        }
      ]
    },
    {
      "id": "QUEUE_NO_DEDUP",
      "name": "Job missing deduplication",
      "category": "queues",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "Duplicate jobs processed",
        "Wasted resources",
        "Inconsistent state"
      ],
      "fix": [
        "Add idempotency keys",
        "Configure removeOnComplete",
        "Use deduplication options"
      ],
      "recommendation": {
        "title": "Add job deduplication",
        "description": "Prevent duplicate jobs using idempotency keys.",
        "library": "Bull, Redis"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "removeOnComplete|removeOnFail|dedup",
          "message": "Deduplication config found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "QUEUE_NO_PRIORITY",
      "name": "Job queue missing priority",
      "category": "queues",
      "severity": "low",
      "frameworks": [],
      "catches": [
        "All jobs treated equally",
        "Critical jobs delayed",
        "Poor user experience"
      ],
      "fix": [
        "Add priority to jobs",
        "Create separate queues",
        "Process by priority"
      ],
      "recommendation": {
        "title": "Use priority queues",
        "description": "Prioritize critical jobs over background tasks.",
        "library": "Bull"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "priority|highPriority|lowPriority",
          "message": "Priority configuration found",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    },
    {
      "id": "QUEUE_SYNCHRONOUS",
      "name": "Synchronous job in request handler",
      "category": "queues",
      "severity": "high",
      "frameworks": ["express", "fastify", "nextjs", "nuxt"],
      "catches": [
        "Slow HTTP responses",
        "Request timeouts",
        "Poor user experience"
      ],
      "fix": [
        "Add job to queue, don't await",
        "Return immediately to user",
        "Process in background"
      ],
      "recommendation": {
        "title": "Offload to background queue",
        "description": "Long-running tasks should be queued, not processed synchronously.",
        "library": "Bull, Agenda"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "await\\s+.*\\.send\\(|\\.add\\(",
          "message": "Queue call found in request handler",
          "fileExtensions": [".ts", ".js"]
        }
      ]
    }
  ]
}
