{
  "rules": [
    {
      "id": "FASTIFY_SCHEMA_MISSING",
      "name": "No JSON schema for route",
      "category": "security",
      "severity": "medium",
      "frameworks": ["fastify"],
      "catches": [
        "No JSON schema for route",
        "No input validation",
        "No serialization optimization"
      ],
      "fix": [
        "Add JSON schema to routes",
        "Validate input/output",
        "Use fast-json-stringify"
      ],
      "recommendation": {
        "title": "Add JSON schema to route",
        "description": "Fastify routes should have JSON schema for validation and serialization.",
        "library": "Fastify"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "fastify\\.(get|post|put|delete|patch)\\s*\\(",
          "message": "Fastify route detected"
        }
      ]
    },
    {
      "id": "FASTIFY_ASYNC_ERROR",
      "name": "Async route without try-catch",
      "category": "architecture",
      "severity": "high",
      "frameworks": ["fastify"],
      "catches": [
        "Async route without try-catch",
        "Unhandled promise rejection",
        "Crashes on errors"
      ],
      "fix": [
        "Add try-catch to async routes",
        "Use Fastify error handling",
        "Handle rejections properly"
      ],
      "recommendation": {
        "title": "Use async/await properly",
        "description": "Fastify route handlers should use async/await with proper error handling.",
        "library": "Fastify"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "async\\s+(?:function\\s+|)\\s*\\(?",
          "message": "Async function detected"
        }
      ]
    },
    {
      "id": "FASTIFY_RATE_LIMIT_MISSING",
      "name": "No rate limiting",
      "category": "security",
      "severity": "high",
      "frameworks": ["fastify"],
      "catches": [
        "No rate limiting",
        "Vulnerable to abuse",
        "DDoS risk"
      ],
      "fix": [
        "Add @fastify/rate-limit",
        "Configure limits per route",
        "Use Redis for distributed"
      ],
      "recommendation": {
        "title": "Add rate limiting",
        "description": "Add rate limiting to protect against abuse.",
        "library": "@fastify/rate-limit"
      },
      "patterns": [
        {
          "type": "regex",
          "pattern": "rate-?limit",
          "message": "Rate limiting configured"
        }
      ]
    }
  ]
}
